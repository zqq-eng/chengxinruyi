/* pages/adminMall/adminMall.wxss */
.page{
  min-height: 100vh;
  background: #f6f7fb;
  padding-top: 24rpx;   /* 👈 新增：整体离顶部远一点 */
  background: #f6f7fb;
}

.topbar{
  padding: 24rpx 24rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.topbar-title{
  font-size: 32rpx;
  font-weight: 700;
  color: #1b1f2a;
}
.circle-btn{
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,.06);
  color: #1b1f2a;
}

.seg-wrap{ padding: 0 24rpx 16rpx; }
.seg{
  background: #fff;
  border-radius: 999rpx;          /* 椭圆 */
  padding: 8rpx;
  display: flex;
  box-shadow: 0 10rpx 24rpx rgba(0,0,0,.06);
}
.seg-item{
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #6a6f7a;
}
.seg-item.on{
  background: #1b1f2a;
  color: #fff;
  font-weight: 700;
}

.content{ padding: 0 24rpx 40rpx; }

.section-head{
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.section-title{
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1f2a;
}
.hint{
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7b8190;
}

.btn-primary{
  padding: 14rpx 22rpx;
  border-radius: 18rpx;           /* 圆角矩形 */
  background: #1b1f2a;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}
.btn-row{ margin-top: 12rpx; }

.card-list{ margin-top: 16rpx; }

.card{
  background: #fff;
  border-radius: 20rpx;           /* 矩形卡片 */
  padding: 18rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 10rpx 24rpx rgba(0,0,0,.06);
}

.card-row{ display: flex; align-items: flex-start; }

.type-badge{
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;          /* 圆形徽标 */
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}
.type-badge-text{
  color: #fff;
  font-weight: 800;
  font-size: 26rpx;
}
.t-time{ background: #2a7fff; }
.t-dist{ background: #ff7a2a; }
.t-both{ background: #20b26b; }

.card-main{ flex: 1; }
.card-title{
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1f2a;
}
.card-sub{
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6a6f7a;
}
.card-meta{
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8a90a0;
  display: flex;
  align-items: center;
}
.dot{ margin: 0 10rpx; }
.card-cost{
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #1b1f2a;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.cost-sep{ margin: 0 10rpx; color: #8a90a0; }

.pill{
  padding: 6rpx 14rpx;
  border-radius: 999rpx;          /* 胶囊 */
  font-size: 22rpx;
  font-weight: 700;
}
.pill-on{ background: rgba(32,178,107,.12); color: #20b26b; }
.pill-off{ background: rgba(120,120,120,.12); color: #666; }

.card-actions{
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-left: 12rpx;
}
.btn-ghost{
  padding: 10rpx 18rpx;
  border-radius: 16rpx;
  background: #f1f3f7;
  color: #1b1f2a;
  font-size: 22rpx;
  text-align: center;
}
.btn-danger{
  padding: 10rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(255,59,48,.12);
  color: #ff3b30;
  font-size: 22rpx;
  text-align: center;
}

.empty{
  padding: 36rpx 0;
  text-align: center;
  color: #8a90a0;
  font-size: 24rpx;
}

/* 二级分段（订单状态） */
.seg2{
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}
.seg2-item{
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #6a6f7a;
  font-size: 22rpx;
  box-shadow: 0 8rpx 18rpx rgba(0,0,0,.05);
}
.seg2-item.on{
  background: #1b1f2a;
  color: #fff;
  font-weight: 700;
}

.card-title2{ font-size: 26rpx; font-weight: 700; color: #1b1f2a; }
.card-sub2{ margin-top: 8rpx; font-size: 22rpx; color: #6a6f7a; }

/* 弹层 */
.mask{
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.35);
  display: flex;
  align-items: flex-end;
  z-index: 99;
}
.sheet{
  width: 100%;
  background: #fff;
  border-radius: 26rpx 26rpx 0 0;
  padding-bottom: 18rpx;
}
.sheet-head{
  padding: 20rpx 22rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.sheet-title{ font-size: 28rpx; font-weight: 800; color: #1b1f2a; }
.sheet-close{ font-size: 30rpx; color: #6a6f7a; padding: 6rpx 12rpx; }

.sheet-body{ padding: 0 22rpx 18rpx; }
.form-row{ margin-top: 14rpx; }
.label{ font-size: 22rpx; color: #6a6f7a; margin-bottom: 8rpx; }
.ipt{
  background: #f6f7fb;
  border-radius: 16rpx;
  padding: 16rpx 14rpx;
  font-size: 26rpx;
}
.picker{
  background: #f6f7fb;
  border-radius: 16rpx;
  padding: 16rpx 14rpx;
  font-size: 26rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.picker-arrow{ color: #8a90a0; }

.form-grid{
  display: flex;
  gap: 12rpx;
  margin-top: 10rpx;
}
.grid-item{ flex: 1; }
.label2{ font-size: 22rpx; color: #6a6f7a; margin-bottom: 8rpx; }
.ipt2{
  background: #f6f7fb;
  border-radius: 16rpx;
  padding: 16rpx 14rpx;
  font-size: 26rpx;
}
.ta{
  background: #f6f7fb;
  border-radius: 16rpx;
  padding: 16rpx 14rpx;
  font-size: 26rpx;
  min-height: 140rpx;
}

.kv{
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}
.k{ color: #6a6f7a; font-size: 22rpx; }
.v{ color: #1b1f2a; font-size: 22rpx; max-width: 520rpx; text-align: right; }

.sheet-foot{
  padding: 14rpx 22rpx 0;
  display: flex;
  gap: 12rpx;
}
.btn-ghost2{
  flex: 1;
  background: #f1f3f7;
  color: #1b1f2a;
  border-radius: 18rpx;
  text-align: center;
  padding: 16rpx 0;
  font-weight: 700;
}
.btn-primary2{
  flex: 1;
  background: #1b1f2a;
  color: #fff;
  border-radius: 18rpx;
  text-align: center;
  padding: 16rpx 0;
  font-weight: 800;
}
.btn-danger2{
  flex: 1;
  background: rgba(255,59,48,.14);
  color: #ff3b30;
  border-radius: 18rpx;
  text-align: center;
  padding: 16rpx 0;
  font-weight: 800;
}

.notify-panel{
  margin-top: 14rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(0,0,0,.06);
}
/* ====== notify selected users ====== */
.select-wrap { margin-top: 12rpx; }
.select-toolbar{
  display:flex; align-items:center; justify-content:space-between;
  margin: 10rpx 0;
}
.toolbar-btns{ display:flex; gap: 12rpx; }
.user-scroll{
  max-height: 520rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  border-radius: 18rpx;
  overflow: hidden;
}
.user-row{
  display:flex; align-items:center; justify-content:space-between;
  padding: 18rpx 18rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}
.user-row:last-child{ border-bottom: none; }
.user-left{ display:flex; flex-direction:column; min-width: 0; }
.user-name{ font-size: 28rpx; font-weight: 600; }
.user-sub{
  margin-top: 6rpx;
  font-size: 22rpx;
  opacity: 0.65;
  word-break: break-all;
}
.user-right .check{
  width: 44rpx; height: 44rpx;
  display:flex; align-items:center; justify-content:center;
  border-radius: 12rpx;
  border: 1rpx solid rgba(0,0,0,0.15);
}
