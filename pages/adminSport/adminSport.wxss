/* 整体页面：下移 + 渐变背景 + 光斑颗粒感 */
.sport-admin-page {
  min-height: 100vh;
  padding: 56px 18px 28px;   /* 🔥 整体往下挪一点 */
  box-sizing: border-box;

  background:
    radial-gradient(circle at 16% 18%, rgba(255,255,255,0.95), rgba(255,255,255,0) 55%),
    radial-gradient(circle at 82% 78%, rgba(255,255,255,0.9), rgba(255,255,255,0) 55%),
    linear-gradient(180deg, #f8e9ff 0%, #ffeaf5 45%, #f6f7ff 100%);
}

/* 顶部返回栏：和其它后台页统一 */
.top-bar {
  display: flex;
  align-items: center;
  margin-bottom: 14px;
}

.back-btn {
  padding: 4px 16px;
  border-radius: 999px;
  font-size: 13px;
  border: none;
  background: rgba(255, 255, 255, 0.96);
  color: #8b5ade;
  box-shadow: 0 4px 12px rgba(185, 150, 230, 0.45);
}

.top-title {
  margin-left: 10px;
  font-size: 18px;        /* 🔥 字更大 */
  font-weight: 700;
  color: #8a58cf;
}

/* 通用卡片，和 adminPanel / 预约页统一 */
.card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 22px;
  padding: 14px 16px;
  box-shadow: 0 10px 26px rgba(190, 150, 225, 0.4);
  margin-top: 16px;

  animation: cardFadeUp 0.5s ease-out both;
}

.overview-card {
  animation-delay: 0.03s;
}

.table-card {
  animation-delay: 0.08s;
}

/* 顶部总览 */
.ov-row {
  display: flex;
  justify-content: space-between;
}

.ov-block {
  flex: 1;
  text-align: center;
}

.ov-label {
  font-size: 13px;        /* 🔥 原来更小一点 */
  color: #9f80c5;
}

.ov-value {
  margin-top: 4px;
  font-size: 18px;        /* 🔥 更醒目 */
  color: #ff6fa8;
  font-weight: 700;
}

/* 表格标题 */
.table-title {
  font-size: 15px;        /* 🔥 原 14 */
  font-weight: 600;
  color: #a46ed4;
  margin-bottom: 8px;
}

/* 表头 + 行：字体整体放大一点 */
.table-header,
.table-row {
  display: flex;
  align-items: center;
  font-size: 13px;
}

.table-header {
  font-weight: 600;
  color: #8a6caf;
  border-bottom: 1px solid #f0e5ff;
  padding-bottom: 4px;
}

.table-row {
  padding: 8px 0;
  border-bottom: 1px solid #f7edff;
}

.name-col {
  flex: 1.4;
}
.num-col {
  flex: 0.9;
  text-align: right;
}
.op-col {
  flex: 0.9;
  text-align: center;
}

.td,
.th {
  padding: 0 4px;
}

.table-body {
  max-height: 320rpx;
}

.link-text {
  color: #ff6fa8;
}

/* 空数据提示 */
.empty-tip {
  text-align: center;
  font-size: 12px;
  color: #a28bc3;
  margin-top: 10px;
}

/* 详情遮罩 & 面板：上滑动画，字体加大 */
.detail-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.15);
  display: flex;
  justify-content: center;
  align-items: flex-end;
  z-index: 999;
}

.detail-panel {
  width: 100%;
  max-height: 80%;
  background: #ffffff;
  border-radius: 18px 18px 0 0;
  padding: 12px 14px 18px;
  box-shadow: 0 -6px 20px rgba(160, 130, 210, 0.35);

  animation: panelSlideUp 0.4s ease-out both;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-title {
  font-size: 15px;
  font-weight: 600;
  color: #6a4a86;
}

.detail-close {
  font-size: 18px;
  padding: 0 4px;
  color: #a383c4;
}

.detail-meta {
  margin-top: 6px;
  font-size: 12px;
  color: #7f6496;
  display: flex;
  justify-content: space-between;
}

/* 小标题 */
.section-subtitle {
  margin-top: 10px;
  margin-bottom: 4px;
  font-size: 13px;
  color: #a66fd8;
  font-weight: 600;
}

/* 趋势表头 + 行 */
.trend-header,
.trend-row {
  display: flex;
  font-size: 11px;
}

.trend-header {
  font-weight: 600;
  color: #8a6caf;
}

.trend-date {
  flex: 1.4;
}
.trend-num {
  flex: 0.9;
  text-align: right;
}

.trend-body {
  max-height: 160rpx;
}

/* 全部记录列表 */
.runs-body {
  max-height: 220rpx;
  margin-top: 4px;
}

.run-row {
  padding: 4px 0;
  border-bottom: 1px solid #f5eaff;
}

.run-date {
  font-size: 12px;
  color: #8667a3;
}

.run-meta {
  margin-top: 2px;
  font-size: 11px;
  color: #9a7bbd;
}

/* ========== 动画 ========== */

/* 卡片从下往上轻微浮现 */
@keyframes cardFadeUp {
  0% {
    opacity: 0;
    transform: translateY(12px) scale(0.98);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* 详情面板从底部上滑 */
@keyframes panelSlideUp {
  0% {
    opacity: 0;
    transform: translateY(20px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}
