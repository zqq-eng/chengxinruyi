/* pages/adminSport/adminSport.wxss */

/* =========================
   Sport Admin - Detail 美化版（含图表）
========================= */

.sport-admin-page {
  min-height: 100vh;
  padding: 56px 18px 28px;
  box-sizing: border-box;

  background:
    radial-gradient(circle at 16% 18%, rgba(255,255,255,0.95), rgba(255,255,255,0) 56%),
    radial-gradient(circle at 84% 22%, rgba(255,255,255,0.70), rgba(255,255,255,0) 58%),
    radial-gradient(circle at 78% 78%, rgba(255,255,255,0.85), rgba(255,255,255,0) 54%),
    linear-gradient(180deg, #f6fbff 0%, #f3f8ff 32%, #f7f3ff 70%, #ffffff 100%);
  color: #0f172a;
}

.top-bar {
  display: flex;
  align-items: center;
  margin-bottom: 14px;
}

.back-btn {
  padding: 6px 16px;
  border-radius: 999px;
  font-size: 14px;
  border: 1px solid rgba(59,130,246,0.16);
  background: rgba(255, 255, 255, 0.92);
  color: #2563eb;
  box-shadow: 0 10px 24px rgba(37, 99, 235, 0.14);
}

.back-btn:active {
  opacity: 0.72;
  transform: translateY(1px);
}

.top-title {
  margin-left: 10px;
  font-size: 19px;
  font-weight: 900;
  color: #1f3a8a;
  letter-spacing: 0.2px;
}

/* 卡片统一 */
.card {
  position: relative;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 22px;
  padding: 14px 16px;
  margin-top: 16px;

  border: 1px solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 14px 34px rgba(15, 23, 42, 0.10);

  animation: cardFadeUp 0.5s ease-out both;
  overflow: hidden;
}

.card::after {
  content: "";
  position: absolute;
  top: -40%;
  left: -60%;
  width: 55%;
  height: 160%;
  transform: rotate(16deg);
  background: linear-gradient(90deg,
    rgba(255,255,255,0) 0%,
    rgba(59,130,246,0.10) 45%,
    rgba(34,197,94,0.08) 55%,
    rgba(255,255,255,0) 100%
  );
  opacity: 0.0;
  pointer-events: none;
}

.overview-card { animation-delay: 0.03s; }
.table-card { animation-delay: 0.08s; }
.chart-card { animation-delay: 0.06s; }

.overview-card::after,
.table-card::after,
.chart-card::after {
  animation: sweepOnce 700ms ease-out 1 both;
  opacity: 1;
}

/* 顶部总览 */
.ov-row {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  flex-wrap: wrap;
}

.ov-block {
  flex: 1;
  min-width: 140rpx;
  text-align: center;
  border-radius: 16px;
  padding: 10px 8px;

  background: linear-gradient(135deg, rgba(59,130,246,0.08), rgba(34,197,94,0.07));
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.ov-label {
  font-size: 13.5px;
  color: rgba(15, 23, 42, 0.60);
  font-weight: 650;
}

.ov-value {
  margin-top: 6px;
  font-size: 20px;
  color: #0f172a;
  font-weight: 900;
  letter-spacing: 0.2px;
}

.ov-small {
  font-size: 14px;
  line-height: 1.2;
}

.ov-tip {
  margin-top: 10px;
  font-size: 12px;
  color: rgba(15,23,42,0.45);
}

/* ================= 图表 ================= */
.chart-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chart-title {
  font-size: 16px;
  font-weight: 900;
  color: #1f3a8a;
}

.chart-toggle {
  display: flex;
  gap: 8px;
}

.toggle-btn {
  padding: 6px 10px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 900;
  color: rgba(15,23,42,0.55);
  background: rgba(15,23,42,0.04);
  border: 1px solid rgba(15,23,42,0.06);
}

.toggle-btn.active {
  color: #2563eb;
  background: rgba(37,99,235,0.10);
  border: 1px solid rgba(37,99,235,0.18);
}

.chart-hint {
  margin-top: 8px;
  font-size: 12px;
  color: rgba(15,23,42,0.45);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chart-clear {
  color: #2563eb;
  font-weight: 900;
}

.trend-canvas {
  width: 100%;
  height: 200px;
  margin-top: 10px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(15,23,42,0.06);
}

/* ================= 表格 ================= */
.table-title {
  font-size: 16px;
  font-weight: 900;
  color: #1f3a8a;
  margin-bottom: 10px;
}

.table-header,
.table-row {
  display: flex;
  align-items: center;
  font-size: 13.5px;
}

.table-header {
  font-weight: 800;
  color: rgba(15, 23, 42, 0.60);
  border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  padding-bottom: 8px;
}

.table-row {
  padding: 10px 0;
  border-bottom: 1px dashed rgba(15, 23, 42, 0.06);
}

.table-row:active {
  background: rgba(59,130,246,0.06);
  border-radius: 12px;
  padding-left: 6px;
  padding-right: 6px;
}

.th, .td { padding: 0 4px; }

.name-col { flex: 1.2; }
.acc-col  { flex: 1.2; color: rgba(15,23,42,0.55); font-size: 12px; }
.num-col  { flex: 0.8; text-align: right; }
.dur-col  { flex: 1.1; text-align: right; font-size: 12px; color: rgba(15,23,42,0.65); }
.op-col   { flex: 0.7; text-align: center; }

.table-body { max-height: 380rpx; }

.link-text {
  color: #2563eb;
  font-weight: 900;
}
.link-text:active { opacity: 0.7; }

.empty-tip {
  text-align: center;
  font-size: 12.5px;
  color: rgba(15, 23, 42, 0.45);
  margin-top: 12px;
}

/* ================= 详情遮罩 ================= */
.detail-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(15, 23, 42, 0.18);
  display: flex;
  justify-content: center;
  align-items: flex-end;
  z-index: 999;

  animation: fadeIn 180ms ease-out both;
}

.detail-panel {
  width: 100%;
  max-height: 82%;
  background: rgba(255,255,255,0.98);
  border-radius: 22px 22px 0 0;
  padding: 14px 14px 18px;

  border-top: 1px solid rgba(15,23,42,0.06);
  box-shadow: 0 -18px 50px rgba(15, 23, 42, 0.16);

  animation: panelSlideUp 0.38s cubic-bezier(.2,.8,.2,1) both;
  overflow: hidden;
  position: relative;
}

.detail-panel::before {
  content: "";
  position: absolute;
  left: 16px;
  right: 16px;
  top: 10px;
  height: 3px;
  border-radius: 999px;
  background: linear-gradient(90deg, rgba(34,197,94,0.35), rgba(59,130,246,0.35));
  opacity: 0.55;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 6px;
}

.detail-title {
  font-size: 16px;
  font-weight: 900;
  color: #0f172a;
}

.detail-close {
  font-size: 20px;
  padding: 0 6px;
  color: rgba(15, 23, 42, 0.45);
}
.detail-close:active { opacity: 0.65; }

.detail-meta {
  margin-top: 10px;
  font-size: 12.5px;
  color: rgba(15, 23, 42, 0.55);
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;

  background: linear-gradient(135deg, rgba(59,130,246,0.08), rgba(34,197,94,0.07));
  border: 1px solid rgba(15, 23, 42, 0.05);
  border-radius: 14px;
  padding: 10px 10px;
}

.section-subtitle {
  margin-top: 12px;
  margin-bottom: 6px;
  font-size: 14px;
  color: #1f3a8a;
  font-weight: 900;
}

/* 趋势表 */
.trend-header,
.trend-row {
  display: flex;
  font-size: 12px;
}

.trend-header {
  font-weight: 900;
  color: rgba(15, 23, 42, 0.55);
  padding: 6px 6px;
}

.trend-row {
  padding: 10px 10px;
  border-radius: 14px;
  margin-bottom: 8px;

  background: rgba(255,255,255,0.92);
  border: 1px solid rgba(15, 23, 42, 0.05);
  box-shadow: 0 10px 22px rgba(15,23,42,0.08);
}

.trend-date { flex: 1.4; }
.trend-num  { flex: 0.9; text-align: right; }

.trend-body { max-height: 160rpx; }

/* 全部记录 */
.runs-body {
  max-height: 220rpx;
  margin-top: 6px;
}

.run-row {
  padding: 10px 10px;
  border-radius: 14px;
  margin-bottom: 8px;

  background: linear-gradient(135deg, rgba(59,130,246,0.07), rgba(34,197,94,0.06));
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.run-row:active {
  opacity: 0.78;
  transform: translateY(1px);
}

.run-date {
  font-size: 13px;
  font-weight: 900;
  color: rgba(15, 23, 42, 0.75);
}

.run-meta {
  margin-top: 4px;
  font-size: 12px;
  color: rgba(15, 23, 42, 0.55);
  line-height: 1.5;
}

/* 鼓励 */
.encourage-link {
  color: #2563eb;
  font-weight: 900;
}

.enc-modal-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(15,23,42,0.25);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.enc-modal {
  width: 84%;
  background: #fff;
  border-radius: 18px;
  padding: 14px;
  box-shadow: 0 18px 50px rgba(15,23,42,0.18);
}

.enc-title {
  font-size: 16px;
  font-weight: 900;
  color: #0f172a;
}

.enc-hint {
  margin-top: 6px;
  font-size: 12px;
  color: rgba(15,23,42,0.55);
}

.enc-textarea {
  margin-top: 10px;
  background: rgba(15,23,42,0.04);
  border: 1px solid rgba(15,23,42,0.06);
  border-radius: 14px;
  padding: 10px;
  min-height: 90px;
  font-size: 13px;
  color: #0f172a;
}

.enc-btn-row {
  margin-top: 12px;
  display: flex;
  gap: 10px;
}

.enc-btn {
  flex: 1;
  border-radius: 999px;
  font-weight: 900;
  font-size: 14px;
}

.enc-btn.cancel {
  background: rgba(15,23,42,0.06);
  color: rgba(15,23,42,0.70);
}

.enc-btn.confirm {
  background: rgba(37,99,235,0.12);
  color: #2563eb;
}

/* 动画 */
@keyframes cardFadeUp {
  0% { opacity: 0; transform: translateY(12px) scale(0.985); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes panelSlideUp {
  0% { opacity: 0; transform: translateY(22px); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes sweepOnce {
  0%   { transform: translate3d(0,0,0) rotate(16deg); opacity: 0; }
  20%  { opacity: 1; }
  100% { transform: translate3d(260%,0,0) rotate(16deg); opacity: 0; }
}
.export-row{
  margin: 10px 0 6px;
  display: flex;
  gap: 10px;
}
.export-btn{
  flex: 1;
  border-radius: 999px;
  font-weight: 900;
  font-size: 14px;
  background: rgba(37,99,235,0.12);
  color: #2563eb;
  border: 1px solid rgba(37,99,235,0.18);
}
.export-btn.ghost{
  background: rgba(15,23,42,0.06);
  color: rgba(15,23,42,0.72);
  border: 1px solid rgba(15,23,42,0.08);
}
