.ai-page {
  padding: 28rpx;
  padding-top: 64rpx; /* ✅ 顶部更远 */
  box-sizing: border-box;
  background: radial-gradient(circle at top, #eaf7ff 0%, #edfdf6 45%, #ffffff 100%);
  color: #0f172a;
}

/* 顶部留白 */
.ai-top-space{
  height: 18rpx;
}

/* 顶部卡片 */
.top-card {
  background: linear-gradient(135deg, rgba(33,150,243,0.18), rgba(76,175,80,0.16));
  border-radius: 32rpx;
  padding: 26rpx 24rpx 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(33, 150, 243, 0.20);
  margin-bottom: 26rpx;
  border: 1rpx solid rgba(33,150,243,0.12);
}

.top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.title {
  font-size: 36rpx; /* ✅ 字体稍微大一点 */
  font-weight: 800;
  color: #0b1220;
}

.mode-toggle {
  display: flex;
  align-items: center;
}

.mode-text {
  font-size: 24rpx; /* ✅ 略大 */
  color: #334155;
  margin-right: 12rpx;
}

/* 切换按钮 */
.toggle-btn {
  width: 78rpx;
  height: 42rpx;
  border-radius: 40rpx;
  padding: 4rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  transition: all 0.2s;
  box-shadow: inset 0 0 0 1rpx rgba(0,0,0,0.05);
}

.toggle-btn.on {
  background: linear-gradient(135deg, #2196f3, #43a047);
  justify-content: flex-end;
}

.toggle-btn.off {
  background: linear-gradient(180deg, #e5e7eb, #d1d5db);
  justify-content: flex-start;
}

.toggle-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 6rpx 14rpx rgba(0,0,0,0.12);
}

/* -----------------------
   ✅ 三个高光动态圆形区域
------------------------ */
.orb-panel{
  margin-top: 12rpx;
  padding: 18rpx 16rpx 14rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.78), rgba(255,255,255,0.55));
  border: 1rpx solid rgba(33,150,243,0.12);
  box-shadow: 0 10rpx 24rpx rgba(33,150,243,0.10);
}

.orb-panel-title{
  font-size: 26rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 14rpx;
}

.orb-panel-sub{
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #475569;
}

/* 三圆对齐：比例整齐 */
.orb-row{
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

/* 圆形按钮本体 */
.orb{
  flex: 1;
  aspect-ratio: 1 / 1;
  border-radius: 9999rpx;
  position: relative;
  overflow: hidden;

  display: flex;
  align-items: center;
  justify-content: center;

  border: 1rpx solid rgba(33,150,243,0.18);
  box-shadow: 0 16rpx 34rpx rgba(15,23,42,0.12);

  /* 漂浮 + 呼吸 */
  animation: orbFloat 3.8s ease-in-out infinite;
}

.orb-body{ background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.98), rgba(33,150,243,0.18), rgba(33,150,243,0.10)); }
.orb-food{ background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.98), rgba(76,175,80,0.18), rgba(76,175,80,0.10)); }
.orb-stress{ background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.98), rgba(99,102,241,0.16), rgba(59,130,246,0.10)); }

.orb:active{
  transform: scale(0.985);
  opacity: 0.92;
}

/* 发光 halo */
.orb-halo{
  position: absolute;
  width: 120%;
  height: 120%;
  border-radius: 9999rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.0) 35%, rgba(255,255,255,0.0) 60%, rgba(255,255,255,0.25) 100%);
  opacity: 0.55;
  animation: haloPulse 2.2s ease-in-out infinite;
}

/* 两层动态环 */
.orb-ring{
  position: absolute;
  border-radius: 9999rpx;
  border: 2rpx solid rgba(255,255,255,0.55);
  opacity: 0.55;
}

.ring-a{
  width: 82%;
  height: 82%;
  animation: ringSpin 6s linear infinite;
}

.ring-b{
  width: 62%;
  height: 62%;
  border-color: rgba(255,255,255,0.40);
  animation: ringSpin 8s linear reverse infinite;
}

/* 中心内容 */
.orb-core{
  position: relative;
  z-index: 2;
  width: 86%;
  height: 86%;
  border-radius: 9999rpx;

  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;

  background: rgba(255,255,255,0.55);
  border: 1rpx solid rgba(255,255,255,0.55);
  backdrop-filter: blur(6rpx);
}

.orb-main{
  font-size: 30rpx; /* ✅ 更大 */
  font-weight: 900;
  color: #0f172a;
  letter-spacing: 2rpx;
}

.orb-sub{
  margin-top: 2rpx;
  font-size: 24rpx; /* ✅ 更大 */
  font-weight: 800;
  color: #0b4aa2;
}

.orb-hint{
  margin-top: 10rpx;
  font-size: 20rpx;
  color: rgba(15,23,42,0.55);
  font-weight: 700;
}

.orb-loading{
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #0b4aa2;
  font-weight: 900;
  animation: textBlink 1.0s ease-in-out infinite;
}

/* 当前 tab 轻微高亮 */
.orb-active{
  border-color: rgba(33,150,243,0.35);
  box-shadow: 0 18rpx 40rpx rgba(33,150,243,0.18);
}

/* 动画 */
@keyframes orbFloat{
  0%{ transform: translateY(0rpx); }
  50%{ transform: translateY(-6rpx); }
  100%{ transform: translateY(0rpx); }
}

@keyframes haloPulse{
  0%{ transform: scale(0.98); opacity: 0.35; }
  50%{ transform: scale(1.05); opacity: 0.70; }
  100%{ transform: scale(0.98); opacity: 0.35; }
}

@keyframes ringSpin{
  0%{ transform: rotate(0deg); }
  100%{ transform: rotate(360deg); }
}

@keyframes textBlink{
  0%{ opacity: 0.45; }
  50%{ opacity: 1; }
  100%{ opacity: 0.45; }
}

/* 错误提示 */
.error-tip {
  margin-top: 14rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fdecea, #fff1f2);
  color: #d32f2f;
  font-size: 24rpx; /* ✅ 略大 */
  border: 1rpx solid rgba(211,47,47,0.15);
}

.sub-tip {
  margin-top: 12rpx;
  font-size: 24rpx; /* ✅ 略大 */
  color: #334155;
}

/* Tabs */
.tab-bar {
  display: flex;
  margin-top: 18rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, rgba(33,150,243,0.10), rgba(76,175,80,0.10));
  border-radius: 999rpx;
  padding: 6rpx;
  box-shadow: 0 8rpx 20rpx rgba(33,150,243,0.10);
  border: 1rpx solid rgba(33,150,243,0.10);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0; /* ✅ 稍微大一点 */
  font-size: 26rpx;  /* ✅ 稍微大一点 */
  color: #475569;
  border-radius: 999rpx;
  font-weight: 700;
}

.tab-item.active {
  background: linear-gradient(135deg, #ffffff, #f3fffb);
  color: #1e88e5;
  font-weight: 800;
  box-shadow: 0 6rpx 14rpx rgba(76,175,80,0.18);
}

/* 身体 cute 卡片 */
.cute-card {
  position: relative;
  background: linear-gradient(180deg, #ffffff 0%, #f6fffb 100%);
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(33,150,243,0.14);
  border: 1rpx solid rgba(76,175,80,0.10);
}

.cute-header { margin-bottom: 16rpx; }

.cute-title {
  font-size: 30rpx; /* ✅ 略大 */
  font-weight: 800;
  color: #0f172a;
}

.cute-sub {
  margin-top: 4rpx;
  font-size: 24rpx; /* ✅ 略大 */
  color: #64748b;
}

/* 光斑 */
.light-dot {
  position: absolute;
  border-radius: 999rpx;
  opacity: 0.30;
  filter: blur(1rpx);
}

.dot1 {
  width: 110rpx;
  height: 110rpx;
  background: radial-gradient(circle, rgba(33,150,243,0.55), rgba(33,150,243,0.0));
  top: -24rpx;
  right: 40rpx;
}

.dot2 {
  width: 140rpx;
  height: 140rpx;
  background: radial-gradient(circle, rgba(76,175,80,0.55), rgba(76,175,80,0.0));
  bottom: -36rpx;
  left: 30rpx;
}

.cute-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-gap: 16rpx 20rpx;
  margin-top: 12rpx;
}

.cute-label {
  font-size: 24rpx; /* ✅ 略大 */
  color: #334155;
  margin-bottom: 6rpx;
  display: block;
  font-weight: 700;
}

.cute-input-box {
  display: flex;
  align-items: center;
  background: linear-gradient(180deg, #ffffff, #f8fafc);
  border-radius: 999rpx;
  padding: 12rpx 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(33,150,243,0.12);
  border: 1rpx solid rgba(33,150,243,0.10);
}

.cute-input { flex: 1; font-size: 26rpx; }
.cute-unit { font-size: 22rpx; color: #64748b; margin-left: 8rpx; }

.cute-extra-title {
  margin-top: 20rpx;
  font-size: 26rpx; /* ✅ 略大 */
  color: #0f172a;
  font-weight: 800;
}

.cute-textarea {
  margin-top: 10rpx;
  min-height: 140rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff, #f8fafc);
  box-shadow: 0 6rpx 16rpx rgba(33,150,243,0.12);
  font-size: 26rpx; /* ✅ 略大 */
  border: 1rpx solid rgba(76,175,80,0.10);
}

/* 通用 section 卡片 */
.section-card {
  margin-top: 4rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6fffb 100%);
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(33,150,243,0.14);
  border: 1rpx solid rgba(33,150,243,0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 30rpx; /* ✅ 略大 */
  font-weight: 800;
  color: #0f172a;
}

.section-tag {
  margin-top: 4rpx;
  font-size: 24rpx; /* ✅ 略大 */
  color: #64748b;
}

.mini-btn {
  background: linear-gradient(135deg, rgba(33,150,243,0.16), rgba(76,175,80,0.16));
  color: #1e88e5;
  border-radius: 999rpx;
  font-size: 24rpx; /* ✅ 略大 */
  box-shadow: 0 6rpx 14rpx rgba(33,150,243,0.10);
  border: 1rpx solid rgba(33,150,243,0.10);
}

.section-body { margin-top: 16rpx; }

.input-area {
  min-height: 160rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff, #f8fafc);
  box-shadow: 0 6rpx 16rpx rgba(33,150,243,0.12);
  font-size: 26rpx; /* ✅ 略大 */
  border: 1rpx solid rgba(76,175,80,0.10);
}

.food-image {
  margin-top: 12rpx;
  width: 100%;
  height: 260rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(0,0,0,0.10);
}

/* 结果标题 + 文本 */
.result-title {
  margin-top: 20rpx;
  font-size: 26rpx; /* ✅ 略大 */
  font-weight: 900;
  color: #0f172a;
}

.section-text {
  font-size: 26rpx; /* ✅ 略大 */
  line-height: 1.65;
  color: #334155;
  white-space: pre-wrap;
}

/* 性别选择 */
.gender-row {
  display: flex;
  justify-content: center;
  gap: 22rpx;
  margin: 18rpx 0 8rpx;
}

.gender-btn {
  padding: 14rpx 34rpx;
  border-radius: 40rpx;
  background: linear-gradient(180deg, #f8fafc, #f1f5f9);
  color: #334155;
  font-size: 26rpx; /* ✅ 略大 */
  border: 2rpx solid rgba(33,150,243,0.10);
  transition: all 0.25s ease;
  box-shadow: 0 0 12rpx rgba(0,0,0,0.05);
  font-weight: 800;
}

.gender-btn.active {
  background: linear-gradient(135deg, #1e88e5, #43a047);
  color: white;
  border-color: rgba(76,175,80,0.45);
  box-shadow: 0 0 20rpx rgba(76, 175, 80, 0.45);
  transform: scale(1.06);
}
/* =========================
   ✅ 对话框（新增）
========================= */
.chat-box{
  margin-top: 18rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255,255,255,0.90), rgba(255,255,255,0.70));
  border: 1rpx solid rgba(33,150,243,0.10);
  box-shadow: 0 12rpx 26rpx rgba(15,23,42,0.10);
}

.chat-head{
  padding: 16rpx 16rpx 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, rgba(33,150,243,0.10), rgba(76,175,80,0.08));
  border-bottom: 1rpx solid rgba(33,150,243,0.08);
}

.chat-head-title{
  font-size: 26rpx;
  font-weight: 900;
  color: #0f172a;
}

.chat-end-btn{
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(244,63,94,0.14), rgba(255,255,255,0.7));
  border: 1rpx solid rgba(244,63,94,0.18);
  color: #e11d48;
  font-weight: 900;
  font-size: 24rpx;
}

.chat-tip{
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  color: #475569;
  background: rgba(255,255,255,0.65);
  border-bottom: 1rpx solid rgba(15,23,42,0.06);
}

.chat-list{
  height: 420rpx;
  padding: 16rpx 14rpx;
  box-sizing: border-box;
}

.chat-line{
  display: flex;
  margin-bottom: 12rpx;
}
.chat-line.me{ justify-content: flex-end; }
.chat-line.ai{ justify-content: flex-start; }

.bubble{
  max-width: 86%;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(15,23,42,0.06);
  box-shadow: 0 10rpx 20rpx rgba(15,23,42,0.08);
}

.bubble-ai{
  background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(245,251,255,0.85));
  border-top-left-radius: 10rpx;
}
.bubble-me{
  background: linear-gradient(135deg, rgba(33,150,243,0.95), rgba(67,160,71,0.92));
  border-top-right-radius: 10rpx;
}

.bubble-text{
  font-size: 26rpx;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-all;
  color: #0f172a;
}
.chat-line.me .bubble-text{ color: #fff; }

.chat-reply{
  display: flex;
  gap: 12rpx;
  align-items: center;
  padding: 14rpx 14rpx 16rpx;
  border-top: 1rpx solid rgba(15,23,42,0.06);
  background: rgba(255,255,255,0.78);
}

.reply-input{
  flex: 1;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff, #f8fafc);
  border: 1rpx solid rgba(33,150,243,0.12);
  box-shadow: 0 8rpx 18rpx rgba(33,150,243,0.10);
  font-size: 26rpx;
}

.reply-send{
  height: 72rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1e88e5, #43a047);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 22rpx rgba(33,150,243,0.22);
  border: 1rpx solid rgba(255,255,255,0.25);
}

.reply-send:active{
  transform: scale(0.98);
  opacity: 0.92;
}

.chat-anchor{ height: 1rpx; }
