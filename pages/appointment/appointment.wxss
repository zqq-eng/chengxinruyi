/* 页面整体：淡入动画 + 高级灰蓝背景 */
.appointment-page {
  padding: 16px 12px 22px;
  background: linear-gradient(180deg, #f6f8fc 0%, #edf2fb 100%);
  animation: pageFadeIn 0.6s ease-out;
}

/* 页面淡入动画 */
@keyframes pageFadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 通用文字颜色 */
.ap-sub {
  font-size: 12px;
  color: #4d5f80;
  margin: 4px 2px 8px;
  line-height: 1.5;
}

/* 顶部装饰：高级玻璃拟态 + 蓝色光影 */
.ap-deco-cloud {
  width: 90px;
  height: 38px;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 999px;
  backdrop-filter: blur(10px);
  top: 6vh;
  right: 14px;
  box-shadow: 0 8px 22px rgba(60, 100, 200, 0.25);
  animation: cloudFloat 4s ease-in-out infinite;
}

/* 浮动动画（高级动效） */
@keyframes cloudFloat {
  0%   { transform: translateY(0px); }
  50%  { transform: translateY(-6px); }
  100% { transform: translateY(0px); }
}

/* picker 文本样式 */
.picker-display {
  display: flex;
  align-items: center;
  min-height: 40px;
  font-size: 14px;
  color: #1a3d6f;
}

/* 容器行布局 */
.flex-row { display: flex; }
.flex-half { flex: 1; }

/* 文本域：玻璃拟态 + 鼠标/触摸聚焦动画 */
.textarea-input {
  min-height: 70px;
  line-height: 1.5;
  border-radius: 10px;
  padding: 10px;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(6px);
  border: 1px solid #c5d7f2;
  font-size: 13px;
  color: #1a365d;
  transition: box-shadow 0.25s, transform 0.25s;
}

.textarea-input:focus {
  box-shadow: 0 0 12px rgba(46, 115, 255, 0.35);
  transform: translateY(-2px);
}

/* 无预约提示文本 */
.no-ap {
  font-size: 12px;
  color: #5a6c8f;
  margin: 6px 4px;
}

/* 预约卡片：高级玻璃效果 + 进入动画 */
.ap-item {
  margin-top: 12px;
  padding: 12px 12px 10px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(12px);
  box-shadow: 0 6px 22px rgba(80, 110, 180, 0.15);
  animation: cardRise 0.45s ease-out;
  transition: transform 0.2s, box-shadow 0.2s;
}

/* 卡片进入动画 */
@keyframes cardRise {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 卡片按压动效 */
.ap-item:active {
  transform: scale(0.97);
  box-shadow: 0 4px 14px rgba(50, 80, 150, 0.18);
}

/* 顶部行 */
.ap-row-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 类型标题：高级深蓝色 */
.ap-type {
  font-size: 15px;
  color: #1d3f74;
  font-weight: 600;
}

/* 状态徽章：渐变 + 高级感 */
.ap-status {
  font-size: 12px;
  padding: 3px 10px;
  border-radius: 999px;
  font-weight: 500;
  letter-spacing: 0.3px;
  transition: all 0.25s;
}

/* 各状态的高级渐变色 */
.status-pending {
  background: linear-gradient(135deg, #dce8ff, #bfd3ff);
  color: #2b62b5;
}

.status-accepted {
  background: linear-gradient(135deg, #d9f7e5, #b4eccf);
  color: #1f7a45;
}

.status-rejected {
  background: linear-gradient(135deg, #ffe0ea, #ffd0df);
  color: #3c5bc2;
}

.status-finished {
  background: linear-gradient(135deg, #dde2ff, #c7d0ff);
  color: #3d4fb6;
}

/* 中间内容 */
.ap-row-mid {
  font-size: 12px;
  color: #4b5f83;
  margin-top: 6px;
}

/* 备注 */
.ap-remark {
  font-size: 12px;
  color: #445772;
  margin-top: 6px;
}
/* === 底部返回按钮区域 === */
.bottom-back-wrapper {
  position: fixed;
  bottom: env(safe-area-inset-bottom);
  left: 0;
  width: 100%;
  padding: 14px 20px calc(env(safe-area-inset-bottom) + 10px);
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(12px);
  box-shadow: 0 -4px 18px rgba(90, 120, 180, 0.15);
  z-index: 999;
}

/* 高级蓝色渐变返回按钮 */
.back-btn {
  width: 100%;
  padding: 12px 0;
  border-radius: 999px;
  border: none;

  background: linear-gradient(135deg, #2f80ed, #1c4b9e);
  color: #ffffff;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 1px;

  box-shadow: 0 6px 20px rgba(46, 115, 255, 0.35);
  transition: transform 0.15s ease-out, box-shadow 0.15s ease-out;
}

/* 点击动画：轻微缩放 + 阴影收缩 */
.back-btn:active {
  transform: scale(0.96);
  box-shadow: 0 3px 10px rgba(46, 115, 255, 0.25);
}
