/* 整体滚动容器 */
.comm-page {
  height: 100vh;
  box-sizing: border-box;
  padding: 70rpx 24rpx 40rpx;
  position: relative;
}

/* 浮动装饰：不挡住滑动 */
.float-deco {
  position: fixed;
  z-index: -1;
  pointer-events: none;
}

.deco-bubble-1 {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 20%, #ffffff, #ffd6ff);
  top: 110rpx;
  left: 12rpx;
  opacity: 0.8;
  animation: floatUp 12s ease-in-out infinite;
}

.deco-bubble-2 {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 70% 30%, #ffffff, #c9f0ff);
  bottom: 160rpx;
  right: 16rpx;
  opacity: 0.7;
  animation: floatUp 14s ease-in-out infinite reverse;
}

.deco-cloud-1 {
  width: 180rpx;
  height: 90rpx;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.92);
  bottom: 60rpx;
  left: 40rpx;
  box-shadow: 0 12rpx 30rpx rgba(180, 180, 255, 0.35);
  animation: cloudDrift 18s linear infinite;
}

/* 通用卡片 */
.card {
  margin-top: 20rpx;
  padding: 24rpx 22rpx 26rpx;
  border-radius: 30rpx;
  background: radial-gradient(circle at 0 0, #fff7ff 0, #ffffff 40%, #f1f5ff 100%);
  box-shadow: 0 16rpx 40rpx rgba(195, 165, 255, 0.45);
}

/* 发布卡片特殊 */
.post-card {
  animation: cardIn 0.6s ease-out both;
}

/* 标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #a45ad0;
  margin-bottom: 18rpx;
}

/* 输入区域 */
.input-wrapper {
  margin-top: 10rpx;
}

.input-label {
  font-size: 24rpx;
  color: #9d80b8;
  margin-bottom: 8rpx;
}

/* 这里复用项目里的 .pink-input 样式 */
.text-area {
  min-height: 120rpx;
}

/* 图片选择区域 */
.img-row {
  margin-top: 4rpx;
}

.img-picker {
  border-radius: 22rpx;
  border: 1px dashed #f5a7d4;
  background: rgba(255, 255, 255, 0.9);
  padding: 18rpx 12rpx;
  display: flex;
  align-items: center;
}

.img-plus {
  font-size: 34rpx;
  color: #ff84c3;
  margin-right: 12rpx;
}

.img-tip {
  font-size: 24rpx;
  color: #b08ed2;
}

.img-preview-wrap {
  border-radius: 22rpx;
  overflow: hidden;
  background: #ffffff;
}

.img-preview {
  width: 100%;
  height: 260rpx;
}

.img-actions {
  padding: 10rpx 14rpx 12rpx;
  display: flex;
  justify-content: flex-end;
  font-size: 22rpx;
}

.img-change {
  color: #a45ad0;
  margin-right: 18rpx;
}

.img-clear {
  color: #ff5f92;
}

/* 发布按钮 */
.btn-area {
  margin-top: 22rpx;
  display: flex;
  justify-content: center;
}

/* 列表 */
.list-card {
  margin-top: 28rpx;
}

.comm-list {
  margin-top: 8rpx;
}

.comm-item {
  padding: 18rpx 16rpx 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  margin-top: 14rpx;
  box-shadow: 0 10rpx 24rpx rgba(185, 162, 238, 0.35);
}

.comm-header {
  display: flex;
  align-items: center;
}

.comm-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffacd4, #ffc4f1);
  text-align: center;
  line-height: 56rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
  margin-right: 14rpx;
}

.comm-info {
  flex: 1;
}

.comm-name {
  font-size: 26rpx;
  color: #6b4a86;
}

.comm-meta {
  font-size: 22rpx;
  color: #a287c0;
  margin-top: 2rpx;
}

.comm-right {
  display: flex;
  align-items: center;
}

.comm-weight {
  font-size: 26rpx;
  color: #ff4f9a;
  margin-right: 6rpx;
}

.more-dot {
  font-size: 32rpx;
  color: #c2a3e9;
  padding: 0 6rpx;
}

/* 内容文字 */
.comm-mood {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7b5d8e;
  line-height: 1.6;
}

/* 帖子图片 */
.comm-image {
  margin-top: 10rpx;
  width: 100%;
  height: 260rpx;
  border-radius: 20rpx;
}

/* 空列表文案 */
.empty-text {
  font-size: 24rpx;
  color: #a28bc1;
  text-align: center;
  margin-top: 20rpx;
}

/* 底部留白，防止被 TabBar 遮挡 */
.tabbar-space {
  height: 80rpx;
}

/* 动画 */
@keyframes floatUp {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-14rpx);
  }
  100% {
    transform: translateY(0);
  }
}

@keyframes cloudDrift {
  0% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(24rpx);
  }
  100% {
    transform: translateX(0);
  }
}

@keyframes cardIn {
  0% {
    opacity: 0;
    transform: translateY(30rpx) scale(0.97);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
