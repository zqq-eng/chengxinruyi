/* ============ 页面整体 ============ */
.fx-page{
  height: 100vh;
  box-sizing: border-box;
  padding: 96rpx 26rpx 40rpx; /* 顶部整体下移 */
  position: relative;

  background: linear-gradient(180deg, #eaf8ff 0%, #ffffff 35%, #ffffff 100%);
  color: #0f172a;
}

/* ============ 浮动装饰：上下游动态 ============ */
.fx-floating{
  position: fixed;
  z-index: -1;
  pointer-events: none;
  opacity: .95;
}

.fx-bubble-1{
  width: 110rpx; height: 110rpx;
  border-radius: 50%;
  top: 140rpx; left: 18rpx;
  background: radial-gradient(circle at 30% 20%, #fff, rgba(76,175,80,.22));
  animation: fxFloat 10s ease-in-out infinite;
}
.fx-bubble-2{
  width: 150rpx; height: 150rpx;
  border-radius: 50%;
  top: 260rpx; right: 10rpx;
  background: radial-gradient(circle at 70% 25%, #fff, rgba(33,150,243,.20));
  animation: fxFloat 12s ease-in-out infinite reverse;
}
.fx-bubble-3{
  width: 90rpx; height: 90rpx;
  border-radius: 50%;
  bottom: 190rpx; left: 40rpx;
  background: radial-gradient(circle at 30% 20%, #fff, rgba(147,51,234,.16));
  animation: fxFloat 9s ease-in-out infinite;
}
.fx-wave{
  width: 520rpx; height: 160rpx;
  border-radius: 999rpx;
  bottom: 80rpx; right: -120rpx;
  background: rgba(255,255,255,.88);
  box-shadow: 0 18rpx 40rpx rgba(33,150,243,.16);
  animation: fxDrift 16s linear infinite;
}

/* ============ 顶部卡片区 ============ */
.fx-header{
  border-radius: 34rpx;
  padding: 26rpx 22rpx 22rpx;
  background: rgba(255,255,255,.92);
  border: 1rpx solid rgba(15,23,42,.06);
  box-shadow: 0 18rpx 46rpx rgba(33,150,243,.14);
}

/* 标题：更艺术一些（不依赖外部字体） */
.fx-h-title{
  font-size: 42rpx;           /* 大一点 */
  font-weight: 900;
  letter-spacing: 2rpx;
  color: #0b4aa2;
  text-shadow: 0 10rpx 20rpx rgba(33,150,243,.18);
}

.fx-h-sub{
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.55;
}

/* ============ 搜索 ============ */
.fx-search{
  margin-top: 18rpx;
  height: 86rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(30,136,229,.10), rgba(67,160,71,.10));
  border: 1rpx solid rgba(15,23,42,.06);
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  position: relative;
}

.fx-search-icon{
  font-size: 30rpx;
  margin-right: 10rpx;
  opacity: .9;
}

.fx-input{
  flex: 1;
  height: 86rpx;
  font-size: 28rpx;     /* 字体不要太小 */
  color: #0f172a;
}

.fx-clear{
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: rgba(15,23,42,.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: rgba(15,23,42,.65);
}

/* ============ 第一行：圆形按钮居中（横滑） ============ */
.fx-top-row{
  margin-top: 18rpx;
  white-space: nowrap;
}

.fx-top-inner{
  display: flex;
  justify-content: center;
  gap: 18rpx;
  padding: 6rpx 6rpx 2rpx;
}

/* ============ 3*3 网格 ============ */
.fx-grid-wrap{
  margin-top: 16rpx;
}

.fx-grid{
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

/* ============ 圆形按钮（统一） ============ */
.fx-circle-btn{
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  position: relative;
  overflow: hidden;

  display: flex;
  align-items: center;
  justify-content: center;

  background: radial-gradient(circle at 30% 22%, #ffffff 0%, rgba(33,150,243,.14) 45%, rgba(76,175,80,.10) 100%);
  border: 2rpx solid rgba(33,150,243,.18);
  box-shadow: 0 18rpx 40rpx rgba(33,150,243,.14);

  /* 动态浮动 */
  animation: fxBob 6.8s ease-in-out infinite;
}

.fx-circle-btn.small{
  width: 138rpx;
  height: 138rpx;
  animation-duration: 7.4s;
}

.fx-circle-txt{
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
  padding: 0 12rpx;
  color: #0f172a;
}

.fx-circle-txt.small{
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(15,23,42,.9);
}

/* 圆形按钮光晕 */
.fx-circle-glow{
  position: absolute;
  inset: -30rpx;
  background: radial-gradient(circle at 30% 20%, rgba(255,255,255,.9), rgba(255,255,255,0));
  opacity: .75;
  transform: rotate(12deg);
}

/* 选中态：更明显 */
.fx-circle-btn.on{
  border-color: rgba(67,160,71,.55);
  box-shadow: 0 22rpx 55rpx rgba(67,160,71,.20);
}

.fx-circle-btn.on .fx-circle-txt{
  color: #0b4aa2;
}

/* ============ 颜色/大小混搭：给按钮一点“艺术感” ============ */
/* 第一行四个稍大、色调不同 */
.fx-circle-btn.t0{ transform: translateY(0rpx) scale(1.02); }
.fx-circle-btn.t1{ transform: translateY(4rpx) scale(1.00); border-color: rgba(147,51,234,.22); }
.fx-circle-btn.t2{ transform: translateY(-2rpx) scale(1.01); border-color: rgba(244,63,94,.20); }
.fx-circle-btn.t3{ transform: translateY(3rpx) scale(0.99); border-color: rgba(14,165,233,.22); }

/* 网格的九宫格轻微错位，上下游浮动更明显 */
.fx-circle-btn.g0{ animation-delay: .0s; }
.fx-circle-btn.g1{ animation-delay: .6s; }
.fx-circle-btn.g2{ animation-delay: 1.2s; }
.fx-circle-btn.g3{ animation-delay: .9s; }
.fx-circle-btn.g4{ animation-delay: 1.5s; }
.fx-circle-btn.g5{ animation-delay: .3s; }
.fx-circle-btn.g6{ animation-delay: 1.1s; }
.fx-circle-btn.g7{ animation-delay: .7s; }
.fx-circle-btn.g8{ animation-delay: 1.7s; }

/* ============ 列表卡片（保留原结构，强化可读性） ============ */
.fx-list{
  margin-top: 22rpx;
}

.fx-empty{
  margin-top: 18rpx;
  text-align: center;
  color: #64748b;
  font-size: 26rpx;
}

.fx-item{
  margin-top: 18rpx;
  padding: 20rpx 18rpx 18rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(33,150,243,.06), rgba(76,175,80,.04));
  border: 1rpx solid rgba(15,23,42,.06);
  box-shadow: 0 14rpx 34rpx rgba(33,150,243,.12);
}

.fx-item-top{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.fx-item-title{
  flex: 1;
  font-size: 30rpx;     /* 混搭：比摘要大 */
  font-weight: 900;
  color: #0f172a;
  line-height: 1.25;
}

.fx-pill{
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #2e7d32;
  background: rgba(67,160,71,.12);
  border: 1rpx solid rgba(67,160,71,.18);
  white-space: nowrap;
}

.fx-item-summary{
  margin-top: 10rpx;
  font-size: 26rpx;     /* 字不要太小 */
  line-height: 1.7;
  color: #334155;
}

.fx-tagrow{
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.fx-tag{
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #0b4aa2;
  background: rgba(30,136,229,.10);
  border: 1rpx solid rgba(30,136,229,.12);
}

.fx-item-btn{
  margin-top: 12rpx;
  text-align: right;
  font-size: 24rpx;
  font-weight: 800;
  color: #0b4aa2;
}

.fx-space{
  height: 80rpx;
}

/* ============ 动画 ============ */
@keyframes fxFloat{
  0%{ transform: translateY(0) }
  50%{ transform: translateY(-18rpx) }
  100%{ transform: translateY(0) }
}

@keyframes fxDrift{
  0%{ transform: translateX(0) }
  50%{ transform: translateX(26rpx) }
  100%{ transform: translateX(0) }
}

@keyframes fxBob{
  0%{ transform: translateY(0) }
  50%{ transform: translateY(-10rpx) }
  100%{ transform: translateY(0) }
}
/* ================== 自定义大弹窗（高级UI）================== */
.fx-modal-mask{
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(15, 23, 42, 0.55);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx 18rpx 34rpx;
}

/* 大卡片：更大更高级 */
.fx-modal{
  width: 100%;
  max-width: 720rpx;
  border-radius: 34rpx;
  overflow: hidden;

  background: rgba(255,255,255,.96);
  border: 1rpx solid rgba(15,23,42,.08);
  box-shadow: 0 34rpx 90rpx rgba(0,0,0,.22);
  transform: translateY(0);
}

/* 顶部：标题区域 */
.fx-modal-header{
  position: relative;
  padding: 22rpx 22rpx 16rpx;
  background: linear-gradient(135deg, rgba(30,136,229,.14), rgba(67,160,71,.10));
  border-bottom: 1rpx solid rgba(15,23,42,.06);
}

.fx-modal-title{
  font-size: 34rpx;
  font-weight: 900;
  color: #0f172a;
  line-height: 1.25;
  padding-right: 66rpx; /* 留给关闭按钮 */
}

.fx-modal-subrow{
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.fx-modal-pill{
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #2e7d32;
  background: rgba(67,160,71,.12);
  border: 1rpx solid rgba(67,160,71,.18);
}

.fx-modal-count{
  font-size: 22rpx;
  color: rgba(15,23,42,.55);
  font-weight: 700;
}

/* 关闭按钮 */
.fx-modal-close{
  position: absolute;
  right: 16rpx;
  top: 14rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(15,23,42,.10);
  color: rgba(15,23,42,.72);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

/* 内容区：可滚动 */
.fx-modal-body{
  max-height: 68vh; /* 关键：大一点 */
  padding: 18rpx 22rpx 8rpx;
}

.fx-modal-text{
  font-size: 28rpx;
  line-height: 1.85;
  color: #1f2937;
  white-space: pre-wrap; /* 对 view 有效，但我们用 text，仍保留 */
  word-break: break-word;
  letter-spacing: .4rpx;
}

/* 底部按钮 */
.fx-modal-footer{
  padding: 14rpx 16rpx 18rpx;
  display: flex;
  gap: 14rpx;
  background: rgba(255,255,255,.98);
  border-top: 1rpx solid rgba(15,23,42,.06);
}

.fx-mbtn{
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  color: #ffffff;
  background: linear-gradient(135deg, rgba(30,136,229,.95), rgba(67,160,71,.92));
  box-shadow: 0 16rpx 34rpx rgba(30,136,229,.22);
}

.fx-mbtn.ghost{
  color: #0b4aa2;
  background: rgba(30,136,229,.10);
  border: 1rpx solid rgba(30,136,229,.16);
  box-shadow: none;
}
