/* pages/home/home.wxss */

/* ====== 主题：白底 + 黑字 + 蓝绿 ====== */
.home-page {
  padding: 18px 14px 24px;
  position: relative;
  background: #ffffff;
  color: #111;
}

/* 顶部丝带背景：淡蓝淡绿 */
.top-ribbon {
  position: absolute;
  top: 0;
  left: -40px;
  right: -40px;
  height: 140rpx;
  background: linear-gradient(180deg, rgba(33,150,243,0.12), rgba(76,175,80,0.10));
  opacity: 1;
  z-index: -2;
}

/* 浮动高阶装饰：不挡点击 */
.float-deco {
  position: fixed;
  z-index: -2;
}

/* 云朵 */
.deco-cloud {
  width: 90px;
  height: 36px;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 999px;
  top: 7vh;
  left: -10px;
  box-shadow: 0 6px 18px rgba(33,150,243,0.18);
  animation: gentleFloatCloud 8s ease-in-out infinite;
}

/* 左右装饰：改成蓝绿柔和 */
.deco-flower-left,
.deco-flower-right {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 20%, rgba(33,150,243,0.25), rgba(76,175,80,0.28));
  box-shadow: 0 8px 20px rgba(76,175,80,0.18);
  animation: flowerSpin 10s linear infinite;
}

.deco-flower-left {
  top: 35vh;
  left: -20px;
}

.deco-flower-right {
  top: 18vh;
  right: -18px;
}

/* 闪烁星星：偏蓝 */
.deco-star-1,
.deco-star-2 {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: radial-gradient(circle, #ffffff, rgba(33,150,243,0.35));
  box-shadow: 0 0 12px rgba(33,150,243,0.25);
  animation: starBlink 2.6s ease-in-out infinite;
}

.deco-star-1 {
  top: 12vh;
  right: 40px;
}

.deco-star-2 {
  top: 50vh;
  left: 60px;
  animation-delay: 1.2s;
}

/* 浮动动画 */
@keyframes gentleFloatCloud {
  0% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0); }
}

@keyframes flowerSpin {
  0%   { transform: rotate(0deg) translateY(0); }
  50%  { transform: rotate(180deg) translateY(-4px); }
  100% { transform: rotate(360deg) translateY(0); }
}

@keyframes starBlink {
  0%   { opacity: 0.2; transform: scale(0.8); }
  50%  { opacity: 1;   transform: scale(1.2); }
  100% { opacity: 0.2; transform: scale(0.8); }
}

/* 通用卡片：改为白底+蓝绿阴影 */
.fancy-card {
  position: relative;
  margin-top: 18px;
  padding: 16px 16px 18px;
  background: #ffffff;
  border-radius: 22px;
  box-shadow:
    0 8px 18px rgba(33,150,243,0.12),
    0 6px 14px rgba(76,175,80,0.10);
  overflow: hidden;
  animation: cardIn 0.5s ease-out both;
}

.card-hello {
  margin-top: 24px;
}

/* 卡片外描边：蓝绿渐变 */
.fancy-border {
  position: absolute;
  inset: 0;
  border-radius: 22px;
  border: 2px solid transparent;
  background: linear-gradient(
    120deg,
    rgba(33,150,243,0.25),
    rgba(76,175,80,0.25),
    rgba(33,150,243,0.20)
  );
  z-index: -1;
  opacity: 0.45;
}

/* 卡片入场 */
@keyframes cardIn {
  0% { opacity: 0; transform: translateY(16px) scale(0.97); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

/* 顶部问候 */
.home-hello-row {
  display: flex;
  justify-content: space-between;
}

.hello-title {
  font-size: 20px;
  font-weight: 700;
  color: #1976d2; /* 蓝色标题 */
}

.hello-sub {
  margin-top: 4px;
  font-size: 12px;
  color: #4b5563; /* 深灰 */
}

/* 右侧轨道 */
.hello-right {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hello-orbit {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  border: 1px dashed rgba(33,150,243,0.55);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: orbitRotate 8s linear infinite;
}

.orbit-dot {
  position: absolute;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(76,175,80,0.85);
  top: 2px;
  right: 10px;
  box-shadow: 0 0 8px rgba(76,175,80,0.35);
}

.hello-paw-icon {
  font-size: 24px;
}

@keyframes orbitRotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 身体信息 + BMI 圆环 */
.body-info {
  display: flex;
  justify-content: space-between;
  margin-top: 12px;
}

.info-block {
  flex: 1;
  text-align: center;
}

.info-label {
  font-size: 11px;
  color: #6b7280; /* 灰 */
}

.info-value {
  font-size: 17px;
  font-weight: 700;
  color: #111; /* 黑 */
  margin-top: 3px;
}

.info-unit {
  font-size: 11px;
  margin-left: 2px;
  color: #6b7280;
}

/* 对比箭头（只用在 BMI/体重） */
.compare {
  margin-top: 4px;
  font-size: 11px;
  line-height: 1;
}

.trend {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 999px;
}

.trend.up {
  color: #1976d2;
  background: rgba(33,150,243,0.10);
}

.trend.down {
  color: #2e7d32;
  background: rgba(76,175,80,0.12);
}

.trend.flat {
  color: #6b7280;
  background: rgba(107,114,128,0.10);
}

/* BMI 圆环：蓝→绿 */
.bmi-circle-block {
  flex: 1;
  text-align: center;
}

.bmi-ring {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin: 0 auto;
  position: relative;
  background: conic-gradient(
    from 0deg,
    rgba(33,150,243,0.90) 0,
    rgba(76,175,80,0.85) var(--percent),
    #eef2f7 var(--percent)
  );
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 10px rgba(33,150,243,0.18);
}

.bmi-inner {
  width: 80%;
  height: 80%;
  border-radius: 50%;
  background: #ffffff;
}

.bmi-text {
  position: absolute;
  font-size: 12px;
  color: #111;
}

.bmi-label {
  margin-top: 4px;
  font-size: 11px;
  color: #6b7280;
}

.today-tips {
  margin-top: 8px;
  font-size: 12px;
  color: #4b5563;
}

/* 顶部按钮 */
.small-btn-area {
  margin-top: 10px;
  display: flex;
  justify-content: flex-start;
}

.small-btn {
  margin-top: 2px;
  padding: 8px 20px;
  font-size: 13px;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(33,150,243,0.95), rgba(76,175,80,0.95));
  color: #ffffff;
  box-shadow: 0 4px 12px rgba(33,150,243,0.20);
}

/* ====== 今日运动打卡（大圆签到） ====== */
.checkin-card {
  margin-top: 14px;
}

.checkin-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.checkin-title {
  font-size: 15px;
  font-weight: 700;
  color: #2e7d32;
}

.checkin-count {
  font-size: 18px;
  font-weight: 800;
  color: #1976d2;
}

.checkin-center{
  margin-top: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.checkin-circle{
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(33,150,243,0.95), rgba(76,175,80,0.95));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12px 26px rgba(33,150,243,0.22);
}

.checkin-circle-text{
  font-size: 22px;
  font-weight: 900;
  color: #fff;
  letter-spacing: 2px;
}

.checkin-center-sub{
  margin-top: 10px;
  font-size: 13px;
  font-weight: 700;
  color: #111;
}

.checkin-total {
  margin-top: 6px;
  font-size: 12px;
  color: #111;
}

.checkin-undo-btn{
  margin-top: 10px;
  padding: 8px 18px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
  color: #1976d2;
  background: rgba(33,150,243,0.10);
}

.checkin-sub {
  margin-top: 6px;
  font-size: 12px;
  color: #6b7280;
  line-height: 1.6;
  text-align: center;
}

/* ====== 并列入口卡片 ====== */
.proto-row {
  margin-top: 14px;
  display: flex;
  gap: 12px;
}

.proto-card {
  flex: 1;
  padding: 14px 12px;
  border-radius: 18px;
  background: #ffffff;
  box-shadow:
    0 8px 18px rgba(33,150,243,0.10),
    0 6px 12px rgba(76,175,80,0.08);
  border: 1px solid rgba(33,150,243,0.10);
  display: flex;
  gap: 10px;
  align-items: center;
}

.proto-icon {
  width: 36px;
  height: 36px;
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(33,150,243,0.12), rgba(76,175,80,0.12));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.proto-main {
  flex: 1;
}

.proto-title {
  font-size: 13px;
  font-weight: 700;
  color: #111;
}

.proto-sub {
  margin-top: 3px;
  font-size: 11px;
  color: #6b7280;
  line-height: 1.4;
}

/* ====== 运动视频卡片 ====== */
.video-card {
  margin-top: 14px;
}

.video-title {
  font-size: 15px;
  font-weight: 700;
  color: #1976d2;
}

.video-sub {
  margin-top: 6px;
  font-size: 12px;
  color: #6b7280;
  line-height: 1.6;
}

/* 配合运动的小计划（原结构不动，仅换色） */
.workout-card {
  margin-top: 14px;
}

.workout-title {
  font-size: 16px;
  font-weight: 700;
  color: #2e7d32;
}

.workout-sub {
  margin-top: 6px;
  font-size: 12px;
  color: #4b5563;
  line-height: 1.6;
}

.workout-tags {
  margin-top: 10px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.workout-tag {
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 11px;
  color: #2e7d32;
  background: rgba(76,175,80,0.12);
  box-shadow: 0 3px 8px rgba(76,175,80,0.10);
}

.workout-btn-area {
  margin-top: 14px;
  display: flex;
  justify-content: center;
}

.workout-btn {
  padding: 10px 32px;
  border-radius: 999px;
  border: none;
  font-size: 14px;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, rgba(33,150,243,0.95), rgba(76,175,80,0.95));
  box-shadow: 0 10px 24px rgba(33,150,243,0.22);
}

/* 温柔建议 + 菜谱推荐（结构不动，仅换色） */
.suggestion-card {
  margin-top: 14px;
}

.section-title {
  font-size: 15px;
  font-weight: 700;
  color: #111;
}

.section-subtitle {
  margin-top: 4px;
  font-size: 11px;
  color: #6b7280;
}

/* 时间段列表 */
.time-list {
  margin-top: 8px;
}

.time-block {
  margin-top: 6px;
  padding: 8px 10px;
  border-radius: 16px;
  background: #ffffff;
  border: 1px solid rgba(33,150,243,0.10);
}

.time-badge {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 999px;
  font-size: 11px;
  color: #2e7d32;
  background: rgba(76,175,80,0.12);
}

.badge-blue {
  color: #1976d2;
  background: rgba(33,150,243,0.12);
}

.time-lines {
  margin-top: 4px;
}

.time-line {
  font-size: 12px;
  color: #374151;
  line-height: 1.6;
}

/* 分割线 */
.divider {
  margin-top: 10px;
  margin-bottom: 6px;
  height: 1px;
  background: linear-gradient(
    90deg,
    rgba(33,150,243,0),
    rgba(33,150,243,0.35),
    rgba(76,175,80,0.35),
    rgba(33,150,243,0)
  );
}

.mt16 {
  margin-top: 10px;
}

.diet-more {
  margin-top: 8px;
  font-size: 11px;
  color: #1976d2;
  text-align: right;
}

/* tabbar 占位 */
.tabbar-space {
  height: 90px;
}
