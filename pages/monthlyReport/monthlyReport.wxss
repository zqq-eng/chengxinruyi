/* pages/xxx/xxx.wxss（按你给的原文件直接“完整最终版”替换）
   ✅ 不改你现有结构，只在底部“加增强”：弹层进入动画、卡片微光、图表容器高光
   ✅ 不做会卡顿的复杂动画（不做无限大范围 blur），只做轻量渐变位移/透明度
*/

.mr-page{
  min-height: 100vh;
  padding: 18px 12px 26px;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eaf9f1 0%, #f6fbff 40%, #ffffff 100%);
  color: #0f172a;
}

.mr-header{
  padding: 6px 2px 14px;
}

.mr-title{
  font-size: 20px;
  font-weight: 900;
  color: #0b4aa2;
}

.mr-sub{
  margin-top: 6px;
  font-size: 12px;
  color: #475569;
}

.mr-card{
  background: #ffffff;
  border-radius: 16px;
  padding: 14px 12px;
  border: 1px solid rgba(15,23,42,0.06);
  box-shadow: 0 10px 24px rgba(33,150,243,0.10);
  margin-bottom: 12px;
}

.mr-summary{
  background: radial-gradient(circle at 15% 15%, #ffffff 0%, rgba(76,175,80,0.12) 45%, rgba(33,150,243,0.10) 100%);
}

.mr-card-title{
  font-size: 14px;
  font-weight: 900;
  color: #0b4aa2;
  margin-bottom: 10px;
}

.mr-grid{
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}

.mr-metric{
  border-radius: 14px;
  padding: 10px 10px;
  background: linear-gradient(135deg, rgba(33,150,243,0.08), rgba(76,175,80,0.08));
  border: 1px solid rgba(15,23,42,0.05);
}

.mr-metric-label{
  font-size: 11px;
  color: #475569;
}

.mr-metric-value{
  margin-top: 6px;
  font-size: 16px;
  font-weight: 900;
  color: #0f172a;
}

.mr-weight-row{
  display: flex;
  gap: 10px;
}

.mr-weight-item{
  flex: 1;
  border-radius: 14px;
  padding: 10px 10px;
  background: linear-gradient(135deg, rgba(76,175,80,0.08), rgba(33,150,243,0.06));
  border: 1px solid rgba(15,23,42,0.05);
}

.mr-weight-label{
  font-size: 11px;
  color: #475569;
}

.mr-weight-value{
  margin-top: 6px;
  font-size: 14px;
  font-weight: 900;
  color: #0f172a;
}

.mr-delta-arrow{
  margin-left: 6px;
  font-weight: 900;
}

.delta-up{ color: #d32f2f; }
.delta-down{ color: #2e7d32; }
.delta-flat{ color: #0b4aa2; }

.mr-tip{
  margin-top: 10px;
  padding: 10px 10px;
  border-radius: 14px;
  background: rgba(33,150,243,0.08);
  color: #334155;
  font-size: 12px;
}

.mr-list{
  margin-top: 6px;
}

.mr-item, .mr-day{
  border-radius: 14px;
  padding: 12px 10px;
  background: #ffffff;
  border: 1px solid rgba(15,23,42,0.06);
  box-shadow: 0 8px 16px rgba(76,175,80,0.06);
  margin-bottom: 10px;
}

.mr-item-top{
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mr-item-date{
  font-size: 13px;
  font-weight: 800;
  color: #0f172a;
}

.mr-item-chip{
  padding: 4px 10px;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(33,150,243,0.12), rgba(76,175,80,0.12));
  color: #0f172a;
  font-size: 11px;
  font-weight: 800;
}

.mr-item-sub{
  margin-top: 6px;
  font-size: 12px;
  color: #475569;
  line-height: 1.55;
}

.mr-day{
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mr-day-date{
  font-size: 13px;
  font-weight: 900;
  color: #0f172a;
}

.mr-day-sub{
  margin-top: 4px;
  font-size: 12px;
  color: #475569;
}

.mr-day-chip{
  padding: 4px 10px;
  border-radius: 999px;
  background: rgba(76,175,80,0.12);
  color: #2e7d32;
  font-size: 11px;
  font-weight: 900;
}

.mr-empty{
  text-align: center;
  color: #64748b;
  font-size: 12px;
  padding: 14px 0;
}

.tabbar-space{
  height: 70px;
}
/* ====== 圆形趋势卡片 ====== */
.mr-circle-wrap{
  display:flex;
  justify-content:center;
  padding: 18rpx 0 6rpx;
}

.mr-circle-card{
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #e8f2ff, #dfe9ff 55%, #f7fbff 100%);
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  box-shadow: 0 14rpx 28rpx rgba(0,0,0,0.08);
  border: 1rpx solid rgba(80,120,255,0.18);
}

.mr-circle-num{
  font-size: 64rpx;
  font-weight: 800;
  color:#2f5dff;
  line-height: 1.1;
}

.mr-circle-text{
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color:#1f2a44;
}

.mr-circle-sub{
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(31,42,68,0.65);
}

/* ====== 弹层趋势图 ====== */
.mr-mask{
  position: fixed;
  left:0; top:0; right:0; bottom:0;
  background: rgba(0,0,0,0.45);
  display:flex;
  align-items:flex-end;
  justify-content:center;
  z-index: 999;
}

.mr-popup{
  width: 100%;
  max-height: 86vh;
  background: #ffffff;
  border-top-left-radius: 26rpx;
  border-top-right-radius: 26rpx;
  padding: 18rpx 18rpx 26rpx;
  overflow: auto;
}

.mr-popup-head{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding: 6rpx 6rpx 14rpx;
}

.mr-popup-title{
  font-size: 30rpx;
  font-weight: 700;
  color:#1f2a44;
}

.mr-popup-close{
  font-size: 24rpx;
  padding: 8rpx 16rpx;
}

.mr-chart-block{
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 18rpx;
  background: #fbfdff;
  border: 1rpx solid rgba(0,0,0,0.06);
}

.mr-chart-title{
  font-size: 26rpx;
  font-weight: 650;
  color:#2a3a5a;
  margin-bottom: 10rpx;
}

.mr-canvas{
  width: 650rpx;   /* 视觉尺寸 */
  height: 340rpx;
}

/* =========================
   ✅ 轻量高光动效增强（新增）
   不改你现有功能，仅增强质感；全部是轻量 opacity/transform
========================= */

/* 弹层渐入 + 上滑 */
.mr-mask{
  /* 让遮罩也有轻微渐入，视觉更“高级” */
  animation: mrFadeIn 180ms ease-out both;
}

.mr-popup{
  /* 上滑进场（仅 transform，不吃性能） */
  animation: mrSlideUp 220ms cubic-bezier(.2,.8,.2,1) both;
  /* 细微内阴影，高级感 */
  box-shadow: 0 -18rpx 40rpx rgba(15,23,42,0.12);
}

/* 图表容器：加“扫光”伪元素（很轻量） */
.mr-chart-block{
  position: relative;
  overflow: hidden;
}

/* 扫光条 */
.mr-chart-block::after{
  content: "";
  position: absolute;
  top: -20%;
  left: -60%;
  width: 55%;
  height: 140%;
  transform: rotate(18deg);
  background: linear-gradient(90deg,
    rgba(255,255,255,0) 0%,
    rgba(47,128,237,0.10) 45%,
    rgba(76,175,80,0.08) 55%,
    rgba(255,255,255,0) 100%
  );
  opacity: 0.0;
  pointer-events: none;
}

/* 弹层打开时：扫光跑一次（不会无限循环，不卡） */
.mr-mask .mr-chart-block::after{
  animation: mrSweepOnce 680ms ease-out 1 both;
  opacity: 1;
}

/* Canvas 本体：触摸反馈（轻微） */
.mr-canvas{
  border-radius: 14rpx;
  /* 防止 canvas 溢出时割裂视觉 */
  overflow: hidden;
}

/* 圆形卡片：轻微呼吸高光（低频率，不卡） */
.mr-circle-card{
  position: relative;
  overflow: hidden;
}

/* 圆形卡片高光 */
.mr-circle-card::after{
  content:"";
  position:absolute;
  inset: -20%;
  background: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.65), rgba(255,255,255,0) 55%);
  opacity: 0.55;
  transform: translate3d(-6%, -6%, 0);
  pointer-events:none;
  animation: mrGlowBreath 2200ms ease-in-out infinite;
}

/* 适配：用户按压时更明显一点（不会影响功能） */
.mr-circle-card:active{
  transform: scale(0.985);
}

/* ===== 动画关键帧 ===== */
@keyframes mrFadeIn{
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes mrSlideUp{
  from { transform: translate3d(0, 16rpx, 0); opacity: 0.92; }
  to   { transform: translate3d(0, 0, 0); opacity: 1; }
}

@keyframes mrSweepOnce{
  0%   { transform: translate3d(0,0,0) rotate(18deg); opacity: 0; }
  20%  { opacity: 1; }
  100% { transform: translate3d(240%,0,0) rotate(18deg); opacity: 0; }
}

@keyframes mrGlowBreath{
  0%,100% { opacity: 0.45; transform: translate3d(-6%, -6%, 0); }
  50%     { opacity: 0.70; transform: translate3d(2%, 2%, 0); }
}
