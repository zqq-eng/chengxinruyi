<particle-bg>
  <view class="profile-page">

    <!-- ====== 头部信息：圆形头像 + 椭圆信息卡 ====== -->
    <view class="card profile-header">
      <view class="profile-row">

        <!-- 头像：圆形 + 可点击上传 -->
        <view class="profile-avatar" bindtap="onAvatarTap">
          <image
            wx:if="{{userInfo.avatarUrl}}"
            class="avatar-img"
            src="{{userInfo.avatarUrl}}"
            mode="aspectFill"
          ></image>
          <view wx:else class="avatar-placeholder">
            {{userInfo.name ? userInfo.name[0] : "我"}}
          </view>

          <!-- 小三角装饰 -->
          <view class="tri-badge"></view>
        </view>

        <!-- 右侧信息 -->
        <view class="profile-info">
          <view class="profile-name">
            {{userInfo.name || '未设置姓名'}}
          </view>
          <view class="profile-meta">
            {{userInfo.school || '陕西高校'}} · {{userInfo.major || '专业未设置'}}
          </view>
          <view class="profile-tip">点击头像可更换个人照片</view>

          <!-- 圆角标签行 -->
          <view class="profile-tag-row">
            <view class="tag-pill">身高：{{userInfo.height || '--'}} cm</view>
            <view class="tag-pill">
              当前体重：{{userInfo.currentWeight || userInfo.targetWeight || '--'}} kg
            </view>
          </view>
        </view>

      </view>
    </view>

    <!-- ====== 功能入口：两个并列椭圆卡片（健康月报 / 心理咨询预约） ====== -->
    <view class="card">
      <view class="section-title">健康与支持</view>

      <view class="oval-grid">
        <!-- 健康月报（新增） -->
        <view class="oval-card oval-green" bindtap="goMonthlyReport">
          <view class="oval-icon">📈</view>
          <view class="oval-title">健康月报</view>
          <view class="oval-sub">本月运动次数 · 体重变化</view>
        </view>

        <!-- 预约心理咨询室（并列） -->
        <view class="oval-card oval-blue" bindtap="goCounselingAppointment">
          <view class="oval-icon">🧠</view>
          <view class="oval-title">心理咨询预约</view>
          <view class="oval-sub">预约学校心理咨询室</view>
        </view>
      </view>
    </view>

    <!-- ====== 基础信息设置（原功能保持） ====== -->
    <view class="card">
      <view class="section-title">基础信息设置</view>

      <view class="input-wrapper">
        <view class="input-label">身高（cm）</view>
        <input class="blue-input" type="digit" value="{{heightInput}}" bindinput="onHeightInput" />
      </view>

      <view class="input-wrapper">
        <view class="input-label">年龄</view>
        <input class="blue-input" type="digit" value="{{ageInput}}" bindinput="onAgeInput" />
      </view>

      <view class="input-wrapper">
        <view class="input-label">性别</view>
        <picker mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGenderChange">
          <view class="blue-input">{{genderOptions[genderIndex]}}</view>
        </picker>
      </view>

      <view class="input-wrapper">
        <view class="input-label">当前体重（kg）</view>
        <input class="blue-input" type="digit" value="{{targetInput}}" bindinput="onTargetInput" />
      </view>

      <view class="btn-area">
        <button class="primary-btn" bindtap="onSaveProfile">
          <text>保存信息</text>
        </button>
      </view>
    </view>

    <!-- ====== 其它信息（保持） ====== -->
    <view class="card" style="height: 237rpx; display: block; box-sizing: border-box; left: 0rpx; top: 0rpx">
      <view class="section-title">其它</view>

      <view class="misc-line">
        <text>版本信息：</text>
        <text class="misc-strong">秤心如意 v1.0 正式版</text>
        
      </view>

      <view class="misc-line">
        <text>作者：</text>
        <text>陕西大学生体重管理课题小组</text>
      </view>
      <view class="misc-line">
        <text>软件技术咨询：</text>
        <text>3372117526@qq.com（张芊芊）</text>
        
      </view>
    </view>



    <view class="tabbar-space"></view>

  </view>
</particle-bg>
