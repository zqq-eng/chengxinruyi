/* 页面整体 */
.profile-page {
  padding: 16px 12px 22px;
  background: #f5f7fb;
}

/* 卡片原样，只是颜色尽量偏蓝（如果全局已有 .card，可以少改） */
.card {
  background: #ffffff;
  border-radius: 12px;
  padding: 14px 12px;
  box-shadow: 0 4px 10px rgba(8, 46, 94, 0.06);
  margin-bottom: 12px;
}

.profile-header {
  margin-bottom: 10px;
}

/* 顶部行 */
.profile-row {
  display: flex;
  align-items: center;
}

/* 头像区域：纯蓝风格 + 圆形 */
.profile-avatar {
  width: 56px;
  height: 56px;
  border-radius: 999px;
  overflow: hidden;
  background: #e3eeff;
  border: 1px solid #2f80ed;
  margin-right: 12px;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  text-align: center;
  line-height: 56px;
  color: #2f80ed;
  font-size: 22px;
  font-weight: 700;
}

/* 用户信息 */
.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 16px;
  color: #13315c;
  font-weight: 600;
}

.profile-meta {
  font-size: 12px;
  color: #5a6c8f;
  margin-top: 2px;
}

.profile-tip {
  font-size: 11px;
  color: #8a9bb8;
  margin-top: 4px;
}

/* 标签行 */
.profile-tag-row {
  margin-top: 10px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.tag-paw {
  padding: 4px 8px;
  border-radius: 10px;
  background: #e0ecff;
  color: #1f4f8f;
  font-size: 11px;
}

/* 基础信息表单 */
.input-wrapper {
  margin-top: 10px;
}

.input-label {
  font-size: 13px;
  color: #334e77;
  margin-bottom: 4px;
}

/* 纯蓝输入框 */
.blue-input {
  padding: 8px 10px;
  border-radius: 8px;
  border: 1px solid #c4d4f5;
  background-color: #f9fbff;
  font-size: 14px;
  color: #1a365d;
}

/* 其它信息 */
.misc-line {
  font-size: 12px;
  color: #5a6c8f;
  margin-top: 4px;
}

.misc-strong {
  color: #1f78ff;
}

/* 菜单项 */
.menu-item {
  padding: 12px 6px;
  font-size: 14px;
  color: #1f4f8f;
  border-bottom: 1px solid #dde3f0;
}

.menu-item:last-child {
  border-bottom: none;
}

/* 主按钮：正式蓝色 */
.primary-btn {
  width: 100%;
  margin-top: 16px;
  padding: 10px 0;
  border-radius: 999px;
  background: #2f80ed;
  color: #ffffff;
  font-size: 15px;
  border: none;
}

.primary-btn:active {
  background: #2563c9;
}

/* 预留底部 Tabbar 空间 */
.tabbar-space {
  height: 60px;
}
