.record-page {
  padding: 16px 16px 80px;
}

.card {
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(14px);
  border-radius: 18px;
  padding: 14px;
  margin-bottom: 14px;
  box-shadow: 0 6px 18px rgba(200,170,230,0.25);
}

.calendar-header {
  display: flex; justify-content: space-between; align-items: center;
}
.cal-title { font-size: 16px; color: #a670d7; font-weight: 600; }
.cal-arrow { font-size: 20px; color: #c08fe6; padding: 4px 10px; }

.calendar-week-row { display: flex; margin-top: 8px; }
.week-cell { flex: 1; text-align: center; color: #b795d2; font-size: 12px; }

.calendar-grid { display: flex; flex-wrap: wrap; margin-top: 6px; }

.day-cell {
  width: 14.28%;
  min-height: 44px;
  padding-top: 4px;
  text-align: center;
  border-radius: 10px;
  position: relative;
}
.day-out .day-number { color: #c8bad6; }
.day-number { font-size: 12px; color: #8667a3; }

/* 体重图标 */
.weight-paw {
  position: absolute; bottom: 4px; left: 6px;
  font-size: 14px;
  color: #ff9acb;
}

/* 运动图标 */
.sport-paw {
  position: absolute; bottom: 4px; right: 4px;
  font-size: 14px;
}

/* 信息编辑 */
.section-title {
  font-size: 15px; font-weight: 600;
  color: #a46ed4;
  margin-bottom: 6px;
}

.input-wrapper { margin-top: 10px; }
.input-label { font-size: 13px; color: #8f7fb3; }

.pink-input {
  width: 100%; padding: 8px 10px;
  border-radius: 10px; margin-top: 4px;
  background: rgba(255,238,247,0.7);
}

.btn-area { margin-top: 12px; }
.irregular-btn {
  width: 100%; padding: 10px;
  border-radius: 30px; color: white;
  background: linear-gradient(135deg,#ffc3e0,#d5b8ff);
}

.detail-line {
  font-size: 13px;
  color: #8257a0;
  margin-bottom: 4px;
}
.back-btn {
  font-size: 14px;
  color: #9b63d4;
  padding: 4px 8px 4px 0;
}
.tabbar-space { height: 80px; }
