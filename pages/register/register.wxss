/* ================= 页面基础（绿蓝简约 · 无水波纹） ================= */
.register-page {
  position: relative;
  min-height: 100vh;
  padding: 88rpx 28rpx 60rpx;
  display: flex;
  justify-content: center;
  align-items: flex-start;

  background:
    radial-gradient(circle at 14% 18%, rgba(46, 213, 115, 0.14), rgba(255,255,255,0) 55%),
    radial-gradient(circle at 86% 16%, rgba(59, 130, 246, 0.14), rgba(255,255,255,0) 58%),
    linear-gradient(180deg, #f2fbf7 0%, #f5faff 55%, #ffffff 100%);

  overflow: hidden;
  color: #0f172a;
}

/* ================= 漂浮装饰（保留，简约） ================= */
.float-deco {
  position: absolute;
  pointer-events: none;
}

.reg-deco-cloud {
  top: 6vh;
  left: -10rpx;
  width: 240rpx;
  height: 86rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 999px;
  box-shadow: 0 18rpx 46rpx rgba(15, 23, 42, 0.10);
  border: 1rpx solid rgba(59,130,246,0.10);
  animation: regCloudFloat 18s ease-in-out infinite;
}

.reg-deco-cloud::before,
.reg-deco-cloud::after {
  content: "";
  position: absolute;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 999px;
  border: 1rpx solid rgba(46,213,115,0.10);
}

.reg-deco-cloud::before {
  width: 92rpx;
  height: 92rpx;
  left: 30rpx;
  top: -34rpx;
}

.reg-deco-cloud::after {
  width: 114rpx;
  height: 114rpx;
  left: 96rpx;
  top: -54rpx;
}

.reg-deco-star {
  top: 18vh;
  right: 10vw;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #ffffff 0%, rgba(59,130,246,0.55));
  box-shadow: 0 0 24rpx rgba(59,130,246,0.35);
  animation: regStarTwinkle 2.6s ease-in-out infinite alternate;
}

/* ================= 外层卡片边框（❌ 去掉水波纹） ================= */
.reg-card-border {
  width: 637rpx;
  min-height: 1064rpx;
  padding: 10rpx;
  border-radius: 54rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;

  box-shadow: 0 40rpx 90rpx rgba(15, 23, 42, 0.12);
  border: 1rpx solid rgba(15,23,42,0.06);

  /* ❌ 纯渐变背景，不再有水波纹 */
  background: linear-gradient(135deg, rgba(46,213,115,0.55), rgba(59,130,246,0.55));
}

/* ================= 卡片本体 ================= */
.reg-card {
  width: 100%;
  min-height: 100%;
  border-radius: 46rpx;
  padding: 48rpx 36rpx 40rpx;
  box-sizing: border-box;

  background:
    radial-gradient(circle at 100% 0%, rgba(255,255,255,0.98), rgba(255,255,255,0.90)),
    linear-gradient(180deg, rgba(255,255,255,0.96), rgba(241, 252, 246, 0.92));

  border: 1rpx solid rgba(15,23,42,0.05);
}

/* ================= 标题（⬆ 稍微大一点） ================= */
.page-title {
  text-align: center;
  font-size: 56rpx;      /* 原 52 */
  font-weight: 900;
  color: #0b3b8f;
  letter-spacing: 1rpx;
}

.reg-subtitle {
  text-align: center;
  margin-top: 14rpx;
  margin-bottom: 30rpx;
  font-size: 28rpx;      /* 原 26 */
  color: rgba(15, 23, 42, 0.60);
}

/* ================= 输入区域 ================= */
.input-wrapper {
  margin-bottom: 24rpx;
}

.input-label {
  margin-left: 10rpx;
  margin-bottom: 12rpx;
  font-size: 28rpx;      /* 原 26 */
  color: rgba(15, 23, 42, 0.72);
  font-weight: 650;
}

.leaf-input {
  width: 100%;
  height: 96rpx;        /* 原 92 */
  padding: 0 28rpx;
  box-sizing: border-box;

  font-size: 32rpx;     /* 原 30 */
  color: #0f172a;

  border-radius: 36rpx;
  border: 2rpx solid rgba(59,130,246,0.22);

  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(245, 255, 250, 0.94));
}

.leaf-input:focus {
  border-color: rgba(46,213,115,0.60);
  box-shadow: 0 0 0 8rpx rgba(46,213,115,0.10);
}

/* ================= 错误提示 ================= */
.error-text {
  margin-top: 12rpx;
  text-align: center;
  font-size: 28rpx;      /* 原 26 */
  font-weight: 700;
  color: #ef4444;
}

/* ================= 按钮（⬆ 字体稍大） ================= */
.btn-area {
  margin-top: 26rpx;
  display: flex;
  justify-content: center;
}

.reg-btn {
  width: 82%;
  height: 100rpx;        /* 原 96 */
  border-radius: 40rpx;

  font-size: 32rpx;      /* 原 30 */
  font-weight: 900;
  color: #ffffff;

  background: linear-gradient(135deg, #2ed573 0%, #3b82f6 100%);
  box-shadow: 0 26rpx 56rpx rgba(59,130,246,0.22);

  border: 1rpx solid rgba(255,255,255,0.25);
}

.irregular-btn {
  border: none;
  line-height: 100rpx;
}

/* ================= 底部跳转 ================= */
.extra-row {
  margin-top: 30rpx;
  text-align: center;
  font-size: 30rpx;      /* 原 28 */
}

.extra-text {
  color: rgba(15, 23, 42, 0.55);
}

.extra-link {
  margin-left: 10rpx;
  font-weight: 900;
  color: #0b3b8f;
}

/* ================= 返回按钮 ================= */
.back-btn{
  position: absolute;
  top: 52rpx;
  left: 32rpx;
  z-index: 20;

  height: 68rpx;
  padding: 0 20rpx;
  border-radius: 999px;

  display: flex;
  align-items: center;

  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(59,130,246,0.18);
  box-shadow: 0 14rpx 30rpx rgba(15,23,42,0.10);
}

.back-icon{
  font-size: 30rpx;     /* 原 28 */
  color: #0b3b8f;
  font-weight: 800;
}

/* ================= 动画（保留轻量） ================= */
@keyframes regCloudFloat {
  0% { transform: translateX(0); }
  50% { transform: translateX(26rpx); }
  100% { transform: translateX(-12rpx); }
}

@keyframes regStarTwinkle {
  0% { transform: scale(0.86); opacity: 0.35; }
  50% { transform: scale(1.20); opacity: 1; }
  100% { transform: scale(0.96); opacity: 0.55; }
}
