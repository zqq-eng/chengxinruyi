<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Register UI - Ripple Highlight Border</title>
  <style>
    :root{
      --bg-1:#f6e9ff;
      --bg-2:#e8f3ff;

      --pink:#ff6fa8;
      --purple:#9a7cf0;

      --text:#2e2a3a;
      --muted:#8f7fb3;

      --card-r:30px;
      --card-pad:28px;

      --ring:3px;              /* 边框粗细（偏大） */
      --shadow: 0 28px 56px rgba(120, 76, 180, .22);
    }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }

    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, "PingFang SC", "Microsoft YaHei", Arial;
      color:var(--text);
      background:
        radial-gradient(1200px 700px at 15% 20%, rgba(255,255,255,.9), transparent 55%),
        radial-gradient(900px 600px at 85% 10%, rgba(255,255,255,.85), transparent 50%),
        linear-gradient(135deg, var(--bg-1), var(--bg-2));
      overflow-x:hidden;
    }

    .register-page{
      position: relative;
      min-height: 100%;
      padding: 44px 18px 30px;
      display:flex;
      justify-content:center;
      align-items:flex-start;
    }

    .wrap{
      width:min(520px, 96vw);
      position:relative;
    }

    /* 装饰 */
    .reg-deco-cloud,
    .reg-deco-star{
      position:absolute;
      pointer-events:none;
      filter: drop-shadow(0 10px 22px rgba(155, 120, 220, .22));
    }

    .reg-deco-cloud{
      width: 120px;
      height: 44px;
      background: rgba(255,255,255,0.9);
      border-radius: 999px;
      top: 4vh;
      left: -10px;
      box-shadow: 0 14px 32px rgba(195, 189, 255, 0.55);
      animation: regCloudFloat 22s linear infinite;
    }
    .reg-deco-cloud::before,
    .reg-deco-cloud::after{
      content:"";
      position:absolute;
      background: rgba(255,255,255,0.92);
      border-radius:999px;
    }
    .reg-deco-cloud::before{ width:54px; height:54px; left:14px; top:-20px; }
    .reg-deco-cloud::after{ width:64px; height:64px; left:46px; top:-30px; }

    .reg-deco-star{
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: radial-gradient(circle, #ffffff, #ffd2ff);
      box-shadow: 0 0 18px rgba(255, 255, 255, 0.92);
      top: 16vh;
      right: 9vw;
      animation: regStarTwinkle 3.0s ease-in-out infinite alternate;
    }

    /* 标题 */
    .title{
      margin: 14px 6px 14px;
      text-align:center;
    }
    .title h1{
      margin:0;
      font-size: 26px;
      letter-spacing:.3px;
    }
    .reg-subtitle{
      font-size: 13px;
      color: rgba(154,124,240,.85);
      text-align: center;
      margin-top: 8px;
      margin-bottom: 16px;
    }

    /*
      关键：边框“水波纹高光”
      - 不使用 mask-composite（兼容坑）
      - 用 background-clip 分层：外层画边框纹理，内层画卡片底
      - 再用伪元素做旋转高光（只在边框区域显示）
    */
    .reg-card{
      position:relative;
      border-radius: var(--card-r);
      padding: var(--card-pad);
      box-shadow: var(--shadow);
      overflow:hidden;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);

      /* 两层背景：第一层是边框(波纹纹理)，第二层是内容底色 */
      background:
        /* 边框波纹层（会被 background-clip 限制在 border-box） */
        repeating-radial-gradient(circle at 30% 20%,
          rgba(255,255,255,.70) 0px,
          rgba(255,255,255,.22) 7px,
          rgba(255,255,255,0) 14px),
        /* 卡片主体底色 */
        radial-gradient(circle at 100% 0%, rgba(255,255,255,0.98), rgba(255,255,255,0.84)),
        linear-gradient(145deg, rgba(255,228,246,0.98), rgba(225,209,255,0.92));

      border: var(--ring) solid transparent;

      /* 让第一层只显示在边框，后面两层显示在内容区 */
      background-origin: border-box;
      background-clip: border-box, padding-box, padding-box;
    }

    /* 内衬柔光（不依赖混合模式） */
    .reg-card .inner-glow{
      position:absolute;
      inset: 1px;
      border-radius: calc(var(--card-r) - 1px);
      background: linear-gradient(180deg, rgba(255,255,255,.60), rgba(255,255,255,.18));
      opacity:.55;
      pointer-events:none;
    }

    /* 旋转高光：覆盖全卡片，但用 border 方式只留边框区域 */
    .reg-card::before{
      content:"";
      position:absolute;
      inset:0;
      border-radius: var(--card-r);
      pointer-events:none;

      /* 这层高光会旋转，看起来像波光流动 */
      background: conic-gradient(from 0deg,
        rgba(255,255,255,0) 0deg,
        rgba(255,255,255,.95) 20deg,
        rgba(255,255,255,0) 60deg,
        rgba(255,255,255,0) 150deg,
        rgba(255,255,255,.75) 175deg,
        rgba(255,255,255,0) 230deg,
        rgba(255,255,255,0) 360deg
      );
      opacity:.55;
      filter: blur(.25px);

      /* 只显示边框：用 inset box-shadow “挖空”中间 */
      box-shadow: inset 0 0 0 calc(var(--ring) + 999px) rgba(0,0,0,0);
      /* 关键：用 padding + background-clip 再限制为边框区 */
      padding: var(--ring);
      -webkit-mask:
        linear-gradient(#000 0 0) content-box,
        linear-gradient(#000 0 0);
      -webkit-mask-composite: xor; /* WebKit 可用 */
              mask-composite: exclude; /* 其他浏览器 */
      animation: ringSpin 6.8s linear infinite;
    }

    /* 外扩散高光 */
    .reg-card::after{
      content:"";
      position:absolute;
      inset:-12px;
      border-radius: calc(var(--card-r) + 12px);
      pointer-events:none;
      background:
        radial-gradient(900px 260px at 30% 0%, rgba(255,255,255,.45), transparent 60%),
        radial-gradient(700px 240px at 90% 30%, rgba(255,255,255,.28), transparent 58%),
        radial-gradient(700px 280px at 20% 90%, rgba(255,255,255,.18), transparent 62%);
      filter: blur(18px);
      opacity:.45;
      animation: glowDrift 5.8s ease-in-out infinite alternate;
      z-index:0;
    }

    /* 内容层级 */
    .reg-card > *{
      position:relative;
      z-index:1;
    }

    .form{
      display:grid;
      gap: 14px;
      margin-top: 2px;
    }

    .field{ display:grid; gap:8px; }
    .label{
      font-size: 13px;
      color: rgba(46,42,58,.82);
      margin-left: 4px;
    }

    .input{
      width:100%;
      height: 46px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,.65);
      background: rgba(255,255,255,.58);
      outline: none;
      padding: 0 14px;
      font-size: 15px;
      color: var(--text);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.8),
        0 10px 26px rgba(150,110,210,.12);
      transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
    }
    .input:focus{
      border-color: rgba(154,124,240,.55);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.85),
        0 16px 34px rgba(150,110,210,.20);
      transform: translateY(-1px);
    }

    .btn-area{
      display:flex;
      justify-content:center;
      margin-top: 16px;
    }

    .reg-btn{
      width: 82%;
      height: 48px;
      border-radius: 18px;
      border: 0;
      cursor:pointer;
      font-size: 15px;
      font-weight: 700;
      letter-spacing:.5px;
      color: white;
      background:
        radial-gradient(80% 140% at 30% 0%, rgba(255,255,255,.55), rgba(255,255,255,0) 45%),
        linear-gradient(135deg, rgba(255,111,168,1), rgba(154,124,240,1));
      box-shadow:
        0 18px 36px rgba(154,124,240,.28),
        0 10px 22px rgba(255,111,168,.18);
      transition: transform .16s ease, box-shadow .16s ease;
      position:relative;
      overflow:hidden;
    }

    .reg-btn::before{
      content:"";
      position:absolute;
      inset:-40px -60px;
      background: linear-gradient(120deg,
        rgba(255,255,255,0) 30%,
        rgba(255,255,255,.55) 50%,
        rgba(255,255,255,0) 70%);
      transform: translateX(-30%) rotate(10deg);
      animation: btnSheen 2.6s ease-in-out infinite;
      opacity:.65;
    }

    .reg-btn:active{
      transform: translateY(1px) scale(.99);
      box-shadow:
        0 12px 26px rgba(154,124,240,.22),
        0 8px 16px rgba(255,111,168,.14);
    }

    .extra-row{
      margin-top: 16px;
      text-align: center;
      font-size: 14px;
    }
    .extra-text{ color: var(--muted); }
    .extra-link{
      color: var(--pink);
      margin-left: 6px;
      font-weight: 700;
      text-decoration:none;
    }
    .extra-link:hover{ text-decoration: underline; }

    @keyframes regCloudFloat{
      0% { transform: translateX(0); }
      50% { transform: translateX(22px); }
      100% { transform: translateX(-10px); }
    }
    @keyframes regStarTwinkle{
      0% { transform: scale(0.85); opacity: 0.35; }
      50% { transform: scale(1.25); opacity: 1; }
      100% { transform: scale(0.95); opacity: 0.55; }
    }
    @keyframes ringSpin{
      0%   { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    @keyframes glowDrift{
      0%   { transform: translateY(0) scale(1); opacity:.38; }
      100% { transform: translateY(-6px) scale(1.02); opacity:.55; }
    }
    @keyframes btnSheen{
      0%   { transform: translateX(-55%) rotate(10deg); opacity:.25; }
      45%  { opacity:.75; }
      100% { transform: translateX(55%) rotate(10deg); opacity:.25; }
    }

    @media (max-width: 420px){
      :root{ --card-pad: 22px; --card-r: 26px; }
      .title h1{ font-size: 24px; }
      .reg-btn{ width: 92%; }
    }
  </style>
</head>

<body>
  <div class="register-page">
    <div class="wrap">
      <div class="reg-deco-cloud"></div>
      <div class="reg-deco-star"></div>

      <div class="title">
        <h1>创建账号</h1>
        <div class="reg-subtitle">简洁 · 柔光 · 水波纹高光边框</div>
      </div>

      <div class="reg-card">
        <div class="inner-glow"></div>

        <form class="form" onsubmit="return false;">
          <div class="field">
            <div class="label">用户名</div>
            <input class="input" type="text" placeholder="请输入用户名" />
          </div>

          <div class="field">
            <div class="label">邮箱</div>
            <input class="input" type="email" placeholder="请输入邮箱" />
          </div>

          <div class="field">
            <div class="label">密码</div>
            <input class="input" type="password" placeholder="请输入密码" />
          </div>

          <div class="btn-area">
            <button class="reg-btn" type="submit">完成注册</button>
          </div>

          <div class="extra-row">
            <span class="extra-text">已有账号？</span>
            <a class="extra-link" href="javascript:void(0)">去登录</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
