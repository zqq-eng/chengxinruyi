/* 整体页面：渐变背景 + 下移 + 粒子感 */
.run-page {
  min-height: 100vh;
  padding: 56px 18px 32px;   /* 🔥 整体往下挪一点 */
  box-sizing: border-box;

  background:
    radial-gradient(circle at 16% 18%, rgba(255,255,255,0.95), rgba(255,255,255,0) 55%),
    radial-gradient(circle at 82% 78%, rgba(255,255,255,0.9), rgba(255,255,255,0) 55%),
    linear-gradient(180deg, #f8e9ff 0%, #ffeaf5 45%, #f6f7ff 100%);
}

/* 顶部返回栏 */
.top-bar {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.back-btn {
  padding: 4px 16px;
  border-radius: 999px;
  font-size: 13px;
  border: none;
  background: rgba(255, 255, 255, 0.96);
  color: #8b5ade;
  box-shadow: 0 4px 12px rgba(185, 150, 230, 0.45);
}

.top-title {
  margin-left: 10px;
  font-size: 18px;
  font-weight: 700;
  color: #8a58cf;
}

/* 通用卡片：和后台统一的玻璃卡片 + 动画 */
.card {
  margin-top: 12px;
  padding: 14px 16px 16px;
  border-radius: 24px;
  background: radial-gradient(circle at 0 0, #ffeefd 0, #ffffff 40%, #eaf2ff 100%);
  box-shadow: 0 10px 30px rgba(208, 176, 255, 0.45);
}

/* 卡片轻微浮现动画 */
.animated-card {
  opacity: 0;
  transform: translateY(16px) scale(0.98);
  animation: cardFloatIn 0.6s ease-out forwards;
}

/* 顶部信息卡片 */
.run-info-card {
  padding-bottom: 16px;
}

.run-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.run-distance-block,
.run-pace-block,
.run-middle {
  flex: 1;
  text-align: center;
}

/* 文案整体大一点，清楚 */
.run-label {
  font-size: 12px;
  color: #9b7bb8;
}

.run-value {
  margin-top: 4px;
  font-size: 26px;
  font-weight: 700;
  color: #ff4f9a;
}

.run-time {
  margin-top: 4px;
  font-size: 20px;
  font-weight: 600;
  color: #6f5a8d;
}

.run-pace {
  margin-top: 4px;
  font-size: 20px;
  font-weight: 600;
  color: #ff9acb;
}

.run-unit {
  font-size: 11px;
  color: #c07ed9;
}

.run-sub {
  margin-top: 8px;
  font-size: 12px;
  color: #9a84b6;
  text-align: center;
}

/* 地图区域 */
.map-card {
  padding: 10px 12px 12px;
}

.run-map {
  width: 100%;
  height: 260px;
  border-radius: 18px;
  overflow: hidden;
}

.map-tip {
  margin-top: 6px;
  font-size: 11px;
  color: #9a84b6;
}

/* 控制按钮卡片 */
.run-control-card {
  margin-top: 14px;
}

.btn-area {
  display: flex;
  justify-content: center;
}

/* 按钮沿用你原来的不规则圆角 + 增强一点动画 */
.irregular-btn {
  padding: 12px 38px;
  border-radius: 999px 60px 999px 60px;
  background: linear-gradient(135deg, #ffd1eb, #f4daff);
  color: #ffffff;
  font-size: 15px;
  border: none;
  box-shadow: 0 10px 22px rgba(255, 154, 203, 0.7);

  transition: transform 0.15s ease-out, box-shadow 0.15s ease-out;
}

.irregular-btn:active {
  transform: translateY(1px) scale(0.98);
  box-shadow: 0 6px 14px rgba(255, 154, 203, 0.55);
}

.stop-btn {
  background: linear-gradient(135deg, #ff9acb, #f286b4);
}

.tabbar-space {
  height: 80px;
}

/* ========== 动画 ========== */
@keyframes cardFloatIn {
  0% {
    opacity: 0;
    transform: translateY(16px) scale(0.98);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
/* 顶部安全区，避免刘海遮挡 */
.top-safe-area {
  height: 40px; /* 可根据机型微调 */
}

/* 顶部返回栏 */
.top-bar {
  display: flex;
  align-items: center;
  padding: 0 12px;
  height: 36px;
  margin-bottom: 8px;
}

.back-btn {
  font-size: 14px;
  color: #9b63d4;
  padding: 4px 8px 4px 0;
}

.top-title {
  font-size: 16px;
  font-weight: 600;
  color: #6a4a86;
  margin-left: 6px;
}

/* 整体下移 */
.page {
  padding-top: 20px !important;
}
