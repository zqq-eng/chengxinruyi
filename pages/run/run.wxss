/* ================= 页面整体：白底 + 蓝绿氛围渐变（更丰富） ================= */
.run-page {
  min-height: 100vh;
  padding: 64px 18px 32px; /* ✅ 整体下移一点点 */
  box-sizing: border-box;

  background:
    radial-gradient(circle at 18% 14%, rgba(46, 125, 250, 0.10), rgba(255, 255, 255, 0) 56%),
    radial-gradient(circle at 84% 78%, rgba(0, 200, 140, 0.10), rgba(255, 255, 255, 0) 56%),
    radial-gradient(circle at 50% 102%, rgba(15, 160, 255, 0.08), rgba(255, 255, 255, 0) 60%),
    linear-gradient(180deg, #ffffff 0%, #fbfdff 45%, #ffffff 100%);

  color: #111111;
}

/* （可选）顶部安全区占位：你如果 wxml 没写就不会影响 */
.top-safe-area {
  height: 12px;
}

/* ================= 顶部返回栏 ================= */
.top-bar {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.back-btn {
  padding: 6px 16px;
  border-radius: 999px;
  font-size: 13px;
  border: 1px solid rgba(25, 118, 210, 0.18);
  background: rgba(255, 255, 255, 0.95);
  color: #1565c0;
  box-shadow: 0 6px 14px rgba(21, 101, 192, 0.10);
}

.back-btn:active {
  opacity: 0.92;
}

.top-title {
  margin-left: 10px;
  font-size: 18px;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.5px;
}

/* ================= 通用卡片：白底玻璃感 + 蓝绿阴影 ================= */
.card {
  margin-top: 12px;
  padding: 14px 16px 16px;
  border-radius: 22px;
  background:
    radial-gradient(circle at 0 0, rgba(46, 125, 250, 0.08) 0, rgba(255, 255, 255, 0.98) 40%, rgba(0, 200, 140, 0.06) 100%);
  border: 1px solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 14px 30px rgba(2, 32, 71, 0.10);
}

/* 卡片轻微浮现动画 */
.animated-card {
  opacity: 0;
  transform: translateY(14px) scale(0.985);
  animation: cardFloatIn 0.55s ease-out forwards;
}

/* ================= 顶部信息卡片 ================= */
.run-info-card {
  padding-bottom: 14px;
}

.run-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.run-metric {
  flex: 1;
  text-align: center;
}

/* 标签 */
.run-label {
  font-size: 12px;
  color: #4b5563;
}

/* 主数值：黑色更专业 */
.run-value {
  margin-top: 6px;
  font-size: 26px;
  font-weight: 800;
  color: #0f172a;
}

/* 单位 */
.run-unit {
  margin-top: 2px;
  font-size: 11px;
  color: #64748b;
}

/* 次级实时数据行 */
.run-sub-row {
  margin-top: 12px;
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
}

.run-chip {
  padding: 6px 10px;
  border-radius: 999px;
  font-size: 12px;
  color: #0f172a;
  background: rgba(25, 118, 210, 0.08);
  border: 1px solid rgba(25, 118, 210, 0.14);
}

/* 让第二个 chip 更偏绿一点 */
.run-chip + .run-chip {
  background: rgba(0, 200, 140, 0.10);
  border-color: rgba(0, 200, 140, 0.18);
}

.run-tip {
  margin-top: 10px;
  font-size: 12px;
  color: #475569;
  text-align: center;
}

/* ================= 地图区域 ================= */
.map-card {
  padding: 10px 12px 12px;
}

.run-map {
  width: 100%;
  height: 260px;
  border-radius: 18px;
  overflow: hidden;
  border: 1px solid rgba(15, 23, 42, 0.08);
}

.map-tip {
  margin-top: 8px;
  font-size: 11px;
  color: #64748b;
}

/* ================= 控制按钮卡片 ================= */
.run-control-card {
  margin-top: 14px;
}

.btn-area {
  display: flex;
  justify-content: center;
}

/* 主按钮：蓝绿渐变，不幼稚 */
.irregular-btn {
  padding: 12px 38px;
  border-radius: 999px 60px 999px 60px;
  background: linear-gradient(135deg, #1976d2, #00c88c);
  color: #ffffff;
  font-size: 15px;
  font-weight: 700;
  border: none;
  box-shadow: 0 14px 26px rgba(25, 118, 210, 0.18);

  transition: transform 0.15s ease-out, box-shadow 0.15s ease-out, opacity 0.15s ease-out;
}

.irregular-btn:active {
  transform: translateY(1px) scale(0.985);
  box-shadow: 0 10px 18px rgba(25, 118, 210, 0.14);
  opacity: 0.96;
}

/* 结束按钮：偏红但不刺眼（专业警示） */
.stop-btn {
  background: linear-gradient(135deg, #ef4444, #f97316);
  box-shadow: 0 14px 26px rgba(239, 68, 68, 0.18);
}

/* tabbar 留白 */
.tabbar-space {
  height: 80px;
}

/* ========== 动画 ========== */
@keyframes cardFloatIn {
  0% {
    opacity: 0;
    transform: translateY(14px) scale(0.985);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
.run-pace-sub{
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #64748b;
}
