<particle-bg>
  <view class="stats-page">

    <!-- 小猫提示 -->
    <view class="cat-box">
      <text class="cat-face">ฅ^•ﻌ•^ฅ</text>
      <text class="cat-msg">{{catMessage}}</text>
    </view>

    <!-- 14天折线图 -->
    <view class="card animate-card">
      <view class="title">📈 最近 14 天跑量趋势</view>

      <canvas 
        canvas-id="lineCanvas"
        id="lineCanvas"
        class="chart animate-scale"
        disable-scroll="true"
        bindtap="tapLineChart"
      ></canvas>

      <!-- 浮动 tooltip -->
      <view wx:if="{{lineTip.show}}" class="tooltip" style="left: {{lineTip.x}}px; top: {{lineTip.y}}px;">
        <view class="tt-date">{{lineTip.date}}</view>
        <view class="tt-value">{{lineTip.km}} km</view>
      </view>
    </view>

    <!-- 6周柱状图 -->
    <view class="card animate-card">
      <view class="title">📊 最近 6 周总跑量</view>

      <canvas 
        canvas-id="barCanvas"
        id="barCanvas"
        class="chart animate-scale"
        disable-scroll="true"
        bindtap="tapBarChart"
      ></canvas>

      <view wx:if="{{barTip.show}}" class="tooltip" style="left: {{barTip.x}}px; top: {{barTip.y}}px;">
        <view class="tt-date">第 {{barTip.week}} 周</view>
        <view class="tt-value">{{barTip.km}} km</view>
      </view>
    </view>

    <!-- 返回按钮 -->
    <view class="floating-back">
      <button class="back-btn" bindtap="goBack">返回</button>
    </view>

  </view>
</particle-bg>
