.stats-page {
  padding: 16px 14px 100px;
}

/* 小猫区域 */
.cat-box {
  text-align: center;
  margin-bottom: 18px;
  animation: floatCat 3s ease-in-out infinite;
}
.cat-face {
  font-size: 32px;
  color: #4fa3ff;
}
.cat-msg {
  margin-top: 6px;
  color: #4e6ba8;
  font-size: 14px;
}
@keyframes floatCat {
  0% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
  100% { transform: translateY(0); }
}

/* 卡片背景 */
.card {
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(12px);
  border-radius: 18px;
  padding: 14px;
  margin-bottom: 16px;
  box-shadow: 0 4px 20px rgba(120,160,230,0.18);
}
.animate-card {
  animation: cardUp .6s ease-out;
}
@keyframes cardUp {
  from { opacity:0; transform: translateY(20px); }
  to   { opacity:1; transform: translateY(0); }
}

/* 图表画布 */
.chart {
  width: 100%;
  height: 260px;
  border-radius: 12px;
  background: #eef3ff;
}
.animate-scale {
  animation: zoomIn .6s ease-out;
}
@keyframes zoomIn {
  from { opacity: 0; transform: scale(.85); }
  to   { opacity: 1; transform: scale(1); }
}

/* 标题 */
.title {
  color: #1f4f8f;
  font-size: 16px;
  font-weight: bold;
}

/* tooltip */
.tooltip {
  position: absolute;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(10px);
  padding: 8px 12px;
  border-radius: 12px;
  box-shadow: 0 4px 12px rgba(120,150,210,0.28);
  animation: fadeIn .2s ease-out;
}
@keyframes fadeIn {
  from { opacity:0; transform: translateY(4px); }
  to   { opacity:1; transform: translateY(0); }
}
.tt-date {
  color: #5070a8;
  font-size: 12px;
}
.tt-value {
  font-size: 14px;
  color: #2a55a8;
  font-weight: bold;
}

/* 返回按钮 */
.floating-back {
  position: fixed;
  bottom: 28px;
  left: 0;
  width: 100%;
  padding: 0 20px;
}
.back-btn {
  width: 100%;
  padding: 14px 0;
  border-radius: 999px;
  color: white;
  font-size: 16px;
  background: linear-gradient(135deg,#2f80ed,#1c4b9e);
  box-shadow: 0 6px 20px rgba(46,115,255,0.35);
}
