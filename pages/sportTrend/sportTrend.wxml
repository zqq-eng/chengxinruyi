<particle-bg>
  <scroll-view scroll-y class="sporttrend-page">
    <!-- 顶部 -->
    <view class="top-bar">
      <button class="back-btn" bindtap="goBack">返回</button>
      <text class="top-title">运动趋势（按天明细）</text>
    </view>

    <!-- 加载中 -->
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{!loading && empty}}">
      <text>最近暂无跑步记录</text>
      <text class="sub">去「运动与训练」→「去跑圈打卡」开始记录吧～</text>
    </view>

    <!-- 列表：按天 -->
    <block wx:for="{{dayGroups}}" wx:key="dateStr">
      <view class="card day-card">
        <view class="day-header">
          <text class="date">{{item.dateStr}}</text>
          <text class="summary">
            总里程 {{item.totalDistanceKm}} km · 总时长 {{item.totalMinutes}} min · {{item.runCount}} 次
          </text>
        </view>

        <!-- 明细表头 -->
        <view class="table header">
          <text class="c1">#</text>
          <text class="c2">距离(km)</text>
          <text class="c3">用时</text>
          <text class="c4">配速</text>
          <text class="c5">移动配速</text>
          <text class="c6">均速</text>
        </view>

        <!-- 明细行 -->
        <block wx:for="{{item.runs}}" wx:key="idx">
          <view class="table row" data-checkinid="{{item.checkinId}}" bindtap="onTapRunItem">
            <text class="c1">{{item.idx}}</text>
            <text class="c2">{{item.distanceKm}}</text>
            <text class="c3">{{item.durationStr}}</text>
            <text class="c4">{{item.paceStr}}</text>
            <text class="c5">{{item.movingPaceStr}}</text>
            <text class="c6">{{item.avgSpeedKmh}}</text>
          </view>
        </block>

        <view class="tip" wx:if="{{!item.runs || !item.runs.length}}">
          <text>当天没有跑步明细</text>
        </view>
      </view>
    </block>

    <view class="tabbar-space"></view>
  </scroll-view>
</particle-bg>
