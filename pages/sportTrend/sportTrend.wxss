/* 页面整体 */
.trend-page {
  padding: 16px 14px 120px;
  animation: fadeIn 0.6s ease-out;
}

@keyframes fadeIn {
  from { opacity:0 }
  to   { opacity:1 }
}
.to-stats-btn {
  margin: 20px auto;
  padding: 14px 0;
  width: 90%;
  border-radius: 999px;
  color: white;
  font-size: 16px;
  background: linear-gradient(135deg,#2f80ed,#1c4b9e);
  box-shadow: 0 6px 20px rgba(46,115,255,0.35);
}

/* 卡片玻璃拟态 */
.card {
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(12px);
  border-radius: 20px;
  padding: 14px;
  margin-bottom: 16px;
  box-shadow: 0 6px 20px rgba(100,140,200,0.18);
}
.animate-card {
  animation: cardUp 0.6s ease-out;
}
@keyframes cardUp {
  from { opacity:0; transform: translateY(30px) }
  to   { opacity:1; transform: translateY(0) }
}

.page-title {
  color: #1f4f8f;
  font-size: 16px;
  font-weight: bold;
}
.sub-text {
  color: #4c5e80;
  font-size: 12px;
  margin-bottom: 6px;
}

/* 图表缩放动画 */
.chart {
  width: 310px;
  height: 160px;
  background: #eef3ff;
  border-radius: 12px;
  margin: 0 auto;
  box-shadow: 0 4px 16px rgba(120,140,210,0.18);
}
.animate-scale {
  animation: zoomIn 0.6s cubic-bezier(.25,.8,.25,1);
}
@keyframes zoomIn {
  from { opacity:0; transform: scale(.7) }
  to   { opacity:1; transform: scale(1) }
}

/* 日期标签淡入动画 */
.day-label {
  width: 10%;
  font-size: 10px;
  text-align: center;
  color: #6a7fa8;
  opacity: 0;
  animation: fadeSlide 0.45s forwards;
}
@keyframes fadeSlide {
  from { opacity:0; transform: translateY(6px) }
  to   { opacity:1; transform: translateY(0) }
}

.row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 6px;
}

/* 爪印动画 */
.paw-item {
  width: 10%;
  text-align: center;
  opacity: 0;
  font-size: 14px;
  animation: pawIn .4s forwards, pawSwing 1.5s infinite ease-in-out;
}

@keyframes pawIn {
  from { opacity:0; transform: scale(.5) }
  to   { opacity:1; transform: scale(1) }
}

@keyframes pawSwing {
  0%   { transform: rotate(0deg) }
  25%  { transform: rotate(-10deg) }
  50%  { transform: rotate(6deg) }
  75%  { transform: rotate(-4deg) }
  100% { transform: rotate(0deg) }
}

.legend {
  font-size: 12px;
  color: #4c5e80;
  display: flex;
  justify-content: space-around;
  margin-top: 8px;
}

/* 悬浮返回按钮 */
.floating-back {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 10px);
  left: 0;
  width: 100%;
  padding: 0 20px;
  z-index: 999;
}

.back-btn {
  width: 100%;
  padding: 12px 0;
  background: linear-gradient(135deg, #2f80ed, #1c4b9e);
  border-radius: 999px;
  color: white;
  font-size: 16px;
  font-weight: bold;
  border: none;
  box-shadow: 0 6px 20px rgba(46,115,255,0.35);
  transition: .15s;
}

.back-btn:active {
  transform: scale(.95);
}

.tabbar-space {
  height: 120px;
}
