.sporttrend-page {
  padding: 20rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
  padding: 10rpx 6rpx;
}

.back-btn {
  font-size: 28rpx;
}

.top-title {
  font-size: 32rpx;
  font-weight: 600;
}

.loading, .empty {
  padding: 50rpx 20rpx;
  text-align: center;
  opacity: 0.9;
}

.empty .sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.7;
}

.card.day-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
}

.day-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 12rpx;
}

.day-header .date {
  font-size: 30rpx;
  font-weight: 700;
}

.day-header .summary {
  font-size: 24rpx;
  opacity: 0.75;
}

.table {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
  font-size: 24rpx;
}

.table.header {
  font-weight: 700;
  opacity: 0.9;
}

.table.row {
  opacity: 0.95;
}

.c1 { width: 46rpx; text-align: left; }
.c2 { width: 128rpx; }
.c3 { width: 120rpx; }
.c4 { width: 120rpx; }
.c5 { width: 140rpx; }
.c6 { width: 90rpx; text-align: right; }

.tip {
  padding-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.7;
  text-align: center;
}
