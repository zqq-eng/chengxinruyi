<!-- pages/workout/workout.wxml -->
<particle-bg>
  <scroll-view scroll-y class="workout-page">

    <!-- 顶部返回 + 标题（修复：原来在底部） -->
    <view class="top-bar">
      <button class="back-btn" bindtap="goBack">返回</button>
      <text class="top-title">运动与训练</text>
    </view>

    <!-- 跑步数据卡片（保持原绑定字段不变） -->
    <view class="card stats-card shape-card">
      <!-- 装饰形状：圆 / 椭圆 / 三角 / 矩形 -->
      <view class="shape circle s1"></view>
      <view class="shape oval s2"></view>
      <view class="shape tri s3"></view>
      <view class="shape rect s4"></view>

      <view class="card-header">
        <view class="title-row">
          <text class="card-title">跑步打卡</text>
          <text class="card-sub">蓝绿健康风 · 记录每一步</text>
        </view>
      </view>

      <view class="stats-row">
        <view class="stat-block">
          <view class="stat-label">累计打卡次数</view>
          <view class="stat-value">{{totalDays}}</view>
          <view class="stat-unit">次</view>
        </view>
        <view class="stat-block">
          <view class="stat-label">累计跑步距离</view>
          <view class="stat-value">{{totalDistance}}</view>
          <view class="stat-unit">km</view>
        </view>
        <view class="stat-block">
          <view class="stat-label">累计运动时长</view>
          <view class="stat-value">{{totalMinutes}}</view>
          <view class="stat-unit">min</view>
        </view>
      </view>

      <view class="btn-area">
        <button class="btn-primary" bindtap="goRun">去跑圈打卡</button>
        <button class="btn-secondary" bindtap="goSportTrend">查看运动详情</button>
      </view>
    </view>

    <!-- 手动添加运动记录（保留原逻辑） -->
    

    <!-- 训练视频库（保持原结构 & 绑定不变） -->
    <view class="card video-card shape-card">
      <view class="shape circle s7"></view>
      <view class="shape tri s8"></view>
      <view class="shape rect s9"></view>

      <view class="card-header">
        <view class="title-row">
          <text class="card-title">我的训练视频库</text>
        </view>

        <!-- 分类操作区 -->
        <view class="category-bar">
          <scroll-view scroll-x="true" class="category-scroll">
            <view
              class="category-pill {{item._id === currentCategoryId ? 'active' : ''}}"
              wx:for="{{categories}}"
              wx:key="_id"
              data-id="{{item._id}}"
              data-name="{{item.category}}"
              bindtap="onSelectCategory"
            >
              <text>{{item.category}}</text>
            </view>
          </scroll-view>

          <button class="btn-small" size="mini" bindtap="addCategory">新建分类</button>
        </view>

        <!-- 当前分类 & 上传 -->
        <view class="category-info">
          <text class="current-cat">
            当前分类：
            <text class="highlight">
              {{ currentCategoryName || '请先创建分类' }}
            </text>
          </text>

          <view class="cat-ops" wx:if="{{currentCategoryId}}">
            <button
              class="text-btn"
              size="mini"
              data-id="{{currentCategoryId}}"
              data-name="{{currentCategoryName}}"
              bindtap="renameCategory"
            >重命名</button>

            <button
              class="text-btn danger"
              size="mini"
              data-id="{{currentCategoryId}}"
              bindtap="deleteCategory"
            >删除</button>

            <button
              class="btn-upload"
              size="mini"
              bindtap="uploadVideo"
              loading="{{uploading}}"
            >上传视频</button>
          </view>
        </view>

        <!-- 搜索框 -->
        <view class="search-row">
          <input
            class="search-input"
            placeholder="搜索当前分类中的视频名称"
            value="{{searchKeyword}}"
            bindinput="onSearchInput"
          />
        </view>
      </view>

      <!-- 视频列表 -->
      <view class="video-list" wx:if="{{filteredVideoList.length}}">
        <block wx:for="{{filteredVideoList}}" wx:key="fileID">
          <view class="video-item">
            <view class="thumb">
              <!-- ✅ 封面：优先 coverUrl（如果你后续补了），其次 cover（https snapshot） -->
              <image
                wx:if="{{item.coverUrl || item.cover}}"
                class="thumb-img"
                src="{{item.coverUrl || item.cover}}"
                mode="aspectFill"
              ></image>
              <view wx:else class="thumb-placeholder">
                <text>▶</text>
              </view>
            </view>

            <view class="video-info">
              <text class="video-name">{{item.name}}</text>
              <view class="video-meta">
                <text>{{item.duration}} 秒</text>
                <text> · {{item.sizeMB}} MB</text>
              </view>
              <text class="video-time">上传于 {{item.uploadTime}}</text>

              <view class="video-actions">
                <button
                  class="text-btn primary"
                  size="mini"
                  data-fileid="{{item.fileID}}"
                  bindtap="playVideo"
                >播放</button>

                <button
                  class="text-btn"
                  size="mini"
                  data-index="{{index}}"
                  bindtap="renameVideo"
                >改名</button>

                <button
                  class="text-btn"
                  size="mini"
                  data-index="{{index}}"
                  bindtap="moveVideoUp"
                >上移</button>

                <button
                  class="text-btn"
                  size="mini"
                  data-index="{{index}}"
                  bindtap="moveVideoDown"
                >下移</button>

                <button
                  class="text-btn danger"
                  size="mini"
                  data-index="{{index}}"
                  bindtap="deleteVideo"
                >删除</button>
              </view>
            </view>
          </view>
        </block>
      </view>

      <view class="empty-hint" wx:if="{{!filteredVideoList.length}}">
        <text wx:if="{{!currentCategoryId}}">请先创建一个分类，然后选择分类上传视频~</text>
        <text wx:elif="{{currentCategoryId}}">当前分类还没有视频，点击“上传视频”开始添加吧~</text>
      </view>
    </view>

    <!-- ✅✅✅ 新增：专业锻炼推荐视频栏（右图：大横幅封面+文字压图） -->
    <view class="card recommend-card shape-card">
      <view class="shape oval s5"></view>
      <view class="shape circle s6"></view>

      <view class="recommend-header">
        <view class="recommend-title-wrap">
          <text class="card-title">专业锻炼推荐视频</text>
          <text class="card-sub">官方精选 · 固定推荐（不可编辑）</text>
        </view>

        <button class="btn-small fold-btn" size="mini" bindtap="toggleRecommend" style="width: 125rpx; height: 75rpx; display: block; box-sizing: border-box; left: 0rpx; top: 0rpx">
          {{ recommendCollapsed ? '展开' : '折叠' }}
        </button>
      </view>

      <!-- 折叠时不渲染列表，省空间 -->
      <view wx:if="{{!recommendCollapsed}}">
        <view wx:if="{{recommendList.length}}">
          <block wx:for="{{recommendList}}" wx:key="_id">
            <!-- ✅ 横幅大图卡片 -->
            <view class="recommend-banner">
              <image class="recommend-banner-bg" src="{{item.coverUrl}}" mode="aspectFill"></image>
              <view class="recommend-banner-mask"></view>

              <view class="recommend-banner-content">
                <text class="recommend-banner-title">{{item.title}}</text>

                <view class="recommend-banner-meta">
                  <text wx:if="{{item.duration}}">{{item.duration}}秒</text>
                  <text wx:if="{{item.duration && item.level}}"> · </text>
                  <text wx:if="{{item.level}}">{{item.level}}</text>
                  <text wx:if="{{(item.duration || item.level) && item.note}}"> · </text>
                  <text wx:if="{{item.note}}">{{item.note}}</text>
                </view>
              </view>

              <!-- ✅ 只允许观看 -->
              <button
                class="recommend-banner-play"
                size="mini"
                data-playurl="{{item.playUrl}}"
                data-fileid="{{item.fileID}}"
                bindtap="playRecommend"
              >播放</button>
            </view>
          </block>
        </view>

        <view class="empty-hint" wx:if="{{!recommendList.length}}">
          <text>暂无推荐视频（请在云数据库 recommended_videos 中添加并设为 enabled=true）</text>
        </view>
      </view>
    </view>

    <!-- 视频预览浮层（保留原绑定不变） -->
    <view wx:if="{{previewVisible}}" class="preview-mask" catchtouchmove="true">
      <view class="preview-box">
        <video
          class="preview-video"
          src="{{previewUrl}}"
          controls
          autoplay
        ></video>
        <button class="btn-close" bindtap="closePreview">关闭</button>
      </view>
    </view>

    <view class="tabbar-space"></view>
  </scroll-view>
</particle-bg>
