.workout-page {
  padding: 16rpx 24rpx 120rpx;
  box-sizing: border-box;
  background: radial-gradient(circle at top, #ffe6fa 0%, #f3e5ff 35%, #e0f4ff 70%, #fef6ff 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB",
    "Microsoft YaHei", "Helvetica Neue", Arial, sans-serif;
  color: #4d3b5a;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(136, 93, 172, 0.12);
  padding: 24rpx 24rpx 28rpx;
  margin-bottom: 24rpx;
}

/* ===== 视频库卡片 ===== */
.video-card {
  padding-bottom: 20rpx;
}

.card-header {
  margin-bottom: 12rpx;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #3c2c55;
}

/* 分类条 */
.category-bar {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.category-scroll {
  flex: 1;
  white-space: nowrap;
  padding-right: 16rpx;
}

.category-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 22rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #f6f1ff;
  color: #7e63b6;
  font-size: 24rpx;
}

.category-pill.active {
  background: linear-gradient(135deg, #ff85c0, #b388ff);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 133, 192, 0.35);
}

/* 当前分类信息 */
.category-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.current-cat {
  font-size: 24rpx;
  color: #6f5a98;
}

.highlight {
  font-weight: 600;
}

.cat-ops {
  display: flex;
  align-items: center;
}

/* 搜索框 */
.search-row {
  margin-top: 8rpx;
}

.search-input {
  width: 100%;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #f7f5ff;
  font-size: 24rpx;
}

/* 视频列表 */
.video-list {
  margin-top: 10rpx;
}

.video-item {
  display: flex;
  padding: 18rpx 0;
  border-bottom: 1px solid #f0ecff;
}

.video-item:last-child {
  border-bottom: none;
}

.thumb {
  width: 180rpx;
  height: 110rpx;
  border-radius: 18rpx;
  overflow: hidden;
  margin-right: 18rpx;
}

.thumb-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #ffe0f2, #e2d9ff);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 40rpx;
}

.video-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.video-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #3b2a55;
}

.video-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a78b2;
}

.video-time {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #b0a3cf;
}

.video-actions {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
}

.video-actions .text-btn {
  margin-right: 8rpx;
  margin-top: 6rpx;
}

/* 空状态 */
.empty-hint {
  padding: 24rpx 10rpx 10rpx;
  font-size: 24rpx;
  color: #a18cc3;
}

/* ===== 跑步部分 ===== */

.stats-card .stats-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.stat-block {
  flex: 1;
  text-align: center;
}

.stat-label {
  font-size: 22rpx;
  color: #9b8bc0;
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #4b346d;
}

.stat-unit {
  font-size: 20rpx;
  color: #b6a6d3;
}

.btn-area {
  display: flex;
  justify-content: space-between;
}

.manual-card .section-title {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  color: #4b346d;
}

.manual-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.field {
  flex: 1;
  margin-right: 16rpx;
}

.field:last-child {
  margin-right: 0;
}

.field-label {
  font-size: 22rpx;
  color: #9b8bc0;
  margin-bottom: 6rpx;
}

.field-input {
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: #f7f5ff;
  font-size: 24rpx;
}

/* ===== 预览层 ===== */
.preview-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 7, 30, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.preview-box {
  width: 90%;
  background: #000;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.preview-video {
  width: 100%;
  height: 420rpx;
  background: #000;
}

.btn-close {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  padding: 6rpx 18rpx;
  font-size: 22rpx;
}

/* ===== 按钮样式 ===== */
.btn-primary {
  flex: 1;
  margin-right: 16rpx;
  background: linear-gradient(135deg, #ff7fba, #b58cff);
  color: #ffffff;
  border-radius: 999rpx;
}

.btn-secondary {
  flex: 1;
  background: #f6f1ff;
  color: #7a5eaf;
  border-radius: 999rpx;
}

.btn-small {
  background: #f6f1ff;
  color: #7a5eaf;
  border-radius: 999rpx;
  padding: 0 18rpx;
  height: 52rpx;
  line-height: 52rpx;
}

.btn-upload {
  background: linear-gradient(135deg, #ff85c0, #ffb6d9);
  color: #fff;
  border-radius: 999rpx;
  padding: 0 24rpx;
  height: 52rpx;
  line-height: 52rpx;
}

/* 文本按钮 */
.text-btn {
  background: transparent;
  color: #7b63b3;
  padding: 0 10rpx;
}

.text-btn.primary {
  color: #ff6fa8;
}

.text-btn.danger {
  color: #f36b7f;
}

/* 底部 tabbar 占位 */
.tabbar-space {
  height: 120rpx;
}
