/* 页面整体：绿主蓝辅 + 柔和渐变 */
.workout-page {
  min-height: 100vh;
  padding: 70rpx 24rpx 40rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 16%, rgba(255,255,255,0.96), rgba(255,255,255,0) 56%),
    radial-gradient(circle at 84% 78%, rgba(255,255,255,0.92), rgba(255,255,255,0) 56%),
    linear-gradient(180deg, #e9fff3 0%, #eaf4ff 45%, #ffffff 100%);
}

/* 顶部栏 */
.top-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.back-btn {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  border: none;
  background: rgba(255, 255, 255, 0.92);
  color: #1976d2;
  box-shadow: 0 10rpx 22rpx rgba(25,118,210,0.14);
}

.top-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #0f172a;
}

/* 通用卡片：白底玻璃感 + 蓝绿阴影 */
.card {
  margin-top: 18rpx;
  padding: 26rpx 22rpx;
  border-radius: 30rpx;
  background: radial-gradient(circle at 0 0, #ffffff 0, #ffffff 45%, #f2fbff 100%);
  box-shadow: 0 18rpx 46rpx rgba(25,118,210,0.10);
  border: 2rpx solid rgba(76,175,80,0.10);
  position: relative;
  overflow: hidden;
}

/* 形状卡片装饰 */
.shape-card .shape {
  position: absolute;
  pointer-events: none;
  opacity: 0.20;
}

/* 圆形 */
.shape.circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 30% 30%, #bbdefb, #e3f2fd);
}

/* 椭圆 */
.shape.oval {
  width: 260rpx;
  height: 140rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 30% 30%, #c8e6c9, #e8f5e9);
}

/* 三角形 */
.shape.tri {
  width: 0;
  height: 0;
  border-left: 58rpx solid transparent;
  border-right: 58rpx solid transparent;
  border-bottom: 100rpx solid rgba(25,118,210,0.26);
}

/* 矩形（柔角） */
.shape.rect {
  width: 220rpx;
  height: 110rpx;
  border-radius: 28rpx;
  background: rgba(76,175,80,0.18);
}

/* 位置（每张卡不同组合） */
.s1 { top: -50rpx; right: -50rpx; }
.s2 { bottom: -60rpx; left: -80rpx; }
.s3 { top: 140rpx; left: 16rpx; opacity: 0.16; }
.s4 { bottom: 30rpx; right: -60rpx; opacity: 0.12; }

.s5 { top: -60rpx; left: -90rpx; }
.s6 { bottom: -50rpx; right: -50rpx; opacity: 0.16; }

.s7 { top: -60rpx; right: -60rpx; }
.s8 { top: 190rpx; left: 20rpx; opacity: 0.14; }
.s9 { bottom: -40rpx; left: -60rpx; opacity: 0.12; }

/* 卡头 */
.card-header .title-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
}

.card-sub {
  font-size: 22rpx;
  color: #475569;
}

/* ===================== 跑步统计卡片 ===================== */
.stats-row {
  display: flex;
  gap: 14rpx;
  margin-top: 6rpx;
}

.stat-block {
  flex: 1;
  border-radius: 24rpx;
  padding: 18rpx 12rpx;
  background: linear-gradient(135deg, rgba(25,118,210,0.08), rgba(76,175,80,0.10));
  border: 2rpx solid rgba(25,118,210,0.10);
  text-align: center;
}

.stat-label {
  font-size: 22rpx;
  color: #475569;
}

.stat-value {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 900;
  color: #0f172a;
}

.stat-unit {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #64748b;
}

.btn-area {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.btn-primary {
  flex: 1;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1976d2, #4caf50);
  color: #fff;
  font-size: 28rpx;
  border: none;
}

.btn-secondary {
  flex: 1;
  border-radius: 999rpx;
  background: rgba(25,118,210,0.10);
  color: #1976d2;
  font-size: 28rpx;
  border: 2rpx solid rgba(25,118,210,0.18);
}

/* ===================== 手动添加 ===================== */
.section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 14rpx;
}

.manual-row {
  display: flex;
  gap: 14rpx;
}

.field {
  flex: 1;
}

.field-label {
  font-size: 22rpx;
  color: #475569;
  margin-bottom: 8rpx;
}

.field-input {
  padding: 14rpx 14rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(25,118,210,0.16);
  background: #f8fafc;
  font-size: 26rpx;
  color: #0f172a;
}

/* ===================== 视频库 ===================== */
.category-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
}

.category-scroll {
  flex: 1;
  white-space: nowrap;
}

.category-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  margin-right: 12rpx;
  background: rgba(76,175,80,0.10);
  color: #14532d;
  border: 2rpx solid rgba(76,175,80,0.18);
  font-size: 24rpx;
}

.category-pill.active {
  background: linear-gradient(135deg, rgba(25,118,210,0.16), rgba(76,175,80,0.18));
  color: #0f172a;
  border-color: rgba(25,118,210,0.22);
  font-weight: 800;
}

.btn-small {
  border-radius: 999rpx;
  background: rgba(25,118,210,0.10);
  color: #1976d2;
  border: 2rpx solid rgba(25,118,210,0.18);
}

.category-info {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.current-cat {
  font-size: 24rpx;
  color: #334155;
}

.highlight {
  color: #1976d2;
  font-weight: 800;
}

.cat-ops {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.text-btn {
  border-radius: 999rpx;
  background: #ffffff;
  color: #0f172a;
  border: 2rpx solid rgba(15,23,42,0.10);
}

.text-btn.primary {
  background: rgba(25,118,210,0.10);
  color: #1976d2;
  border-color: rgba(25,118,210,0.18);
}

.text-btn.danger {
  background: rgba(244,67,54,0.08);
  color: #c62828;
  border-color: rgba(244,67,54,0.16);
}

.btn-upload {
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4caf50, #1976d2);
  color: #ffffff;
  border: none;
}

.search-row {
  margin-top: 12rpx;
}

.search-input {
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(25,118,210,0.16);
  background: #f8fafc;
  font-size: 26rpx;
}

/* 视频列表 */
.video-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.video-item {
  display: flex;
  gap: 14rpx;
  padding: 16rpx 14rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,0.96);
  border: 2rpx solid rgba(76,175,80,0.10);
  box-shadow: 0 12rpx 24rpx rgba(76,175,80,0.08);
}

.thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(25,118,210,0.14), rgba(76,175,80,0.14));
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-placeholder text {
  font-size: 34rpx;
  color: #0f172a;
  font-weight: 900;
}

.video-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.video-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
}

.video-meta {
  font-size: 22rpx;
  color: #475569;
}

.video-time {
  font-size: 22rpx;
  color: #64748b;
}

.video-actions {
  margin-top: 6rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.empty-hint {
  margin-top: 14rpx;
  padding: 18rpx 14rpx;
  border-radius: 26rpx;
  background: rgba(25,118,210,0.06);
  border: 2rpx dashed rgba(25,118,210,0.18);
  color: #334155;
  font-size: 24rpx;
}

/* 预览浮层 */
.preview-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx;
  box-sizing: border-box;
}

.preview-box {
  width: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(0,0,0,0.25);
  padding: 16rpx;
  box-sizing: border-box;
}

.preview-video {
  width: 100%;
  height: 420rpx;
  border-radius: 22rpx;
}

.btn-close {
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: rgba(244,67,54,0.10);
  color: #c62828;
  border: 2rpx solid rgba(244,67,54,0.18);
}

/* 底部留白 */
.tabbar-space {
  height: 90rpx;
}
/* ====== 新增：封面图显示 ====== */
.thumb-img{
  width: 120rpx;
  height: 120rpx;
  border-radius: 22rpx;
}

/* ====== 新增：推荐栏头部布局 + 折叠按钮 ====== */
.recommend-header{
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
}
.recommend-title-wrap{
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.fold-btn{
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
}/* ===================== 推荐视频：横幅大图样式 ===================== */
.recommend-banner{
  position: relative;
  width: 100%;
  height: 220rpx;
  border-radius: 28rpx;
  overflow: hidden;
  margin-top: 14rpx;

  background: rgba(255,255,255,0.96);
  border: 2rpx solid rgba(76,175,80,0.10);
  box-shadow: 0 14rpx 30rpx rgba(76,175,80,0.10);
}

.recommend-banner-bg{
  position: absolute;
  left: 0; top: 0;
  width: 100%;
  height: 100%;
}

.recommend-banner-mask{
  position: absolute;
  left: 0; top: 0;
  width: 100%;
  height: 100%;
  /* 右图那种文字压图：底部加深一点 */
  background: linear-gradient(
    90deg,
    rgba(0,0,0,0.40) 0%,
    rgba(0,0,0,0.18) 55%,
    rgba(0,0,0,0.06) 100%
  );
}

.recommend-banner-content{
  position: absolute;
  left: 20rpx;
  right: 140rpx;
  bottom: 20rpx;
  z-index: 2;
}

.recommend-banner-title{
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #ffffff;
  text-shadow: 0 6rpx 16rpx rgba(0,0,0,0.30);
}

.recommend-banner-meta{
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.86);
  text-shadow: 0 6rpx 16rpx rgba(0,0,0,0.25);
}

.recommend-banner-play{
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 3;

  border-radius: 999rpx;
  padding: 0 22rpx;
  height: 60rpx;
  line-height: 60rpx;

  background: rgba(255,255,255,0.92);
  color: #1976d2;
  border: 2rpx solid rgba(255,255,255,0.65);
  box-shadow: 0 12rpx 24rpx rgba(0,0,0,0.18);
}

